@page "/transactions/sales-orders"
@attribute [Authorize(Policy = "transactions.sales-orders.index")]
@rendermode InteractiveServer
@using ErpOne.Application.Common
@using ErpOne.Application.SalesOrders
@using ErpOne.Domain.Entities
@inject ISalesOrderService SoService
@inject NavigationManager Nav
@inject SwalService Swal

<PageTitle>Sales Orders</PageTitle>

<div class="pi">

    <div class="pi-head">
        <div>
            <nav class="crumbs"><a href="/">Home</a><span class="sep">·</span><span>Transactions</span><span class="sep">·</span><span class="here">Sales Orders</span></nav>
            <h1>Sales Orders</h1>
            <p>Manage sales orders and their approvals.</p>
        </div>
        <AuthorizeView Policy="transactions.sales-orders.create">
            <Authorized>
                <div class="pi-actions">
                    <a class="btn btn-primary" href="/transactions/sales-orders/new"><i class="bi bi-plus-lg"></i> Buat SO</a>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    <!-- ── KPI cards ───────────────────────────────────────────── -->
    @if (_dash is not null)
    {
        <div class="kpis">
            <div class="kpi">
                <div class="ic ic-blu"><i class="bi bi-card-list"></i></div>
                <div class="kpi-tx">
                    <div class="v">@_dash.TotalCount.ToString("N0")</div>
                    <div class="l">Total SO</div>
                </div>
            </div>
            <div class="kpi">
                <div class="ic ic-gry"><i class="bi bi-pencil-square"></i></div>
                <div class="kpi-tx">
                    <div class="v">@_dash.DraftCount.ToString("N0")</div>
                    <div class="l">Draft</div>
                </div>
            </div>
            <div class="kpi">
                <div class="ic ic-amb"><i class="bi bi-hourglass-split"></i></div>
                <div class="kpi-tx">
                    <div class="v">@_dash.PendingApprovalCount.ToString("N0")</div>
                    <div class="l">Menunggu Approval</div>
                </div>
            </div>
            <div class="kpi">
                <div class="ic ic-grn"><i class="bi bi-check-circle"></i></div>
                <div class="kpi-tx">
                    <div class="v">@_dash.ConfirmedCount.ToString("N0")</div>
                    <div class="l">Confirmed</div>
                </div>
            </div>
        </div>
    }

    <!-- ── Toolbar: search + status chips ──────────────────────── -->
    <div class="toolbar">
        <div class="search">
            <i class="bi bi-search"></i>
            <input placeholder="Cari nomor SO…" @bind="_search" @bind:event="oninput" @onkeyup="ReloadAsync" />
        </div>
        <div class="chips">
            <button class="chip @(_statusFilter is null ? "on" : "")" @onclick="() => SetStatusAsync(null)">Semua</button>
            @foreach (var s in Enum.GetValues<SalesOrderStatus>())
            {
                <button class="chip @(_statusFilter == s ? "on" : "")" @onclick="() => SetStatusAsync(s)">@s</button>
            }
        </div>
    </div>

    @if (_page is null)
    {
        <div class="pi-loading"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading…</div>
    }
    else if (_page.Total == 0)
    {
        <div class="empty">
            <div class="empty-ic"><i class="bi bi-receipt"></i></div>
            <p>
                @if (string.IsNullOrEmpty(_search) && _statusFilter is null)
                {
                    <span>Belum ada Sales Order. <a href="/transactions/sales-orders/new">Buat yang pertama.</a></span>
                }
                else
                {
                    <span>Tidak ada SO yang cocok dengan filter.</span>
                }
            </p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-top">
                <span class="n">Menampilkan <b>@((_page.Page - 1) * PageSize + 1)–@Math.Min(_page.Page * PageSize, _page.Total)</b> dari <b>@_page.Total.ToString("N0")</b></span>
            </div>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>No. SO</th>
                            <th>Customer</th>
                            <th>Tanggal</th>
                            <th class="r">Total</th>
                            <th class="c">Status</th>
                            <th style="width:64px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _page.Items)
                        {
                            <tr @onclick="() => Open(item.Id)">
                                <td><span class="po-no">@item.SoNumber</span></td>
                                <td class="nm">@item.CustomerName</td>
                                <td class="code">@item.OrderDate.ToString("dd MMM yyyy")</td>
                                <td class="r mono">@item.Currency @item.GrandTotal.ToString("N2")</td>
                                <td class="c"><span class="badge @StatusClass(item.Status)">@item.Status</span></td>
                                <td>
                                    <div class="rowact">
                                        <a class="ia" href="@($"/transactions/sales-orders/{item.Id}")" title="Lihat" @onclick:stopPropagation="true"><i class="bi bi-eye"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_page.TotalPages > 1)
            {
                <div class="card-foot">
                    <Pager Page="_page.Page" TotalPages="_page.TotalPages" OnPageChanged="GoToPageAsync" />
                </div>
            }
        </div>
    }
</div>

@code {
    private const int PageSize = 15;
    private PagedResult<SalesOrderListItemDto>? _page;
    private SalesOrderDashboardDto? _dash;
    private int _currentPage = 1;
    private string? _search;
    private SalesOrderStatus? _statusFilter;

    protected override async Task OnInitializedAsync()
    {
        _dash = await SoService.GetDashboardAsync();
        await LoadAsync();
    }

    private async Task LoadAsync() =>
        _page = await SoService.GetPagedAsync(_currentPage, PageSize, _search, _statusFilter);

    private async Task ReloadAsync()
    {
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task SetStatusAsync(SalesOrderStatus? status)
    {
        _statusFilter = status;
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        _currentPage = page;
        await LoadAsync();
    }

    private void Open(int id) => Nav.NavigateTo($"/transactions/sales-orders/{id}");

    private static string StatusClass(string status) => status switch
    {
        "Draft" => "b-draft",
        "PendingApproval" => "b-warn",
        "Confirmed" => "b-ok",
        "PartiallyDelivered" => "b-info",
        "Delivered" => "b-done",
        "Closed" => "b-closed",
        "Rejected" => "b-danger",
        "Cancelled" => "b-cancel",
        _ => "b-dark"
    };
}
