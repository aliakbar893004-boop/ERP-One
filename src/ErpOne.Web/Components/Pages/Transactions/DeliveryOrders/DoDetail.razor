@page "/transactions/delivery-orders/{Id:int}"
@attribute [Authorize(Policy = "transactions.delivery-orders.index")]
@rendermode InteractiveServer
@using FluentValidation
@using ErpOne.Application.DeliveryOrders
@inject IDeliveryOrderService Do
@inject NavigationManager Nav
@inject SwalService Swal

<PageTitle>@(_do?.DoNumber ?? "Delivery Order")</PageTitle>

<div class="pf">

    <div class="pf-top">
        <div class="crumbs">
            <a href="/transactions/delivery-orders">Transactions</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/transactions/delivery-orders">Delivery Orders</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(_do?.DoNumber ?? "Detail")</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_do is null)
    {
        <div class="pf-alert warn"><i class="bi bi-exclamation-triangle"></i> Delivery order not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="pd-head">
            <h1>@_do.DoNumber</h1>
            <span class="badge @StatusClass(_do.Status)">@_do.Status</span>
            <div class="actions">
                @if (_do.Status == "Draft")
                {
                    <AuthorizeView Policy="transactions.delivery-orders.edit">
                        <Authorized>
                            <a class="btn btn-line" href="@($"/transactions/delivery-orders/{_do.Id}/edit")"><i class="bi bi-pencil"></i> Edit</a>
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Policy="transactions.delivery-orders.post">
                        <Authorized>
                            <button class="btn btn-primary" @onclick="PostAsync" disabled="@_posting"><i class="bi bi-check2-circle"></i> Post</button>
                        </Authorized>
                    </AuthorizeView>
                }
            </div>
        </div>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-receipt"></i></span>
                <h2>Information</h2>
            </div>
            <div class="card-b">
                <div class="info-grid">
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-truck"></i> DO #</span>
                        <span class="v"><span class="grn-no">@_do.DoNumber</span></span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-file-earmark-text"></i> SO #</span>
                        <span class="v"><a href="/transactions/sales-orders/@_do.SalesOrderId">@_do.SoNumber</a></span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-person"></i> Customer</span>
                        <span class="v">@_do.CustomerName</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-box-seam"></i> Warehouse</span>
                        <span class="v">@_do.WarehouseName</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-calendar3"></i> Delivery Date</span>
                        <span class="v">@_do.DeliveryDate.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-clock"></i> Created</span>
                        <span class="v">@_do.CreatedAt.ToString("dd MMM yyyy HH:mm")@(string.IsNullOrEmpty(_do.CreatedBy) ? "" : " · " + _do.CreatedBy)</span>
                    </div>
                    <div class="info-cell wide">
                        <span class="k"><i class="bi bi-sticky"></i> Notes</span>
                        <span class="v @(string.IsNullOrEmpty(_do.Notes) ? "muted-v" : "")">@(_do.Notes ?? "—")</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-box-seam"></i></span>
                <h2>Items</h2>
            </div>
            <div class="card-b">
                <div class="table-responsive">
                    <table class="items">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="r">Ordered</th>
                                <th class="c">Delivered</th>
                                <th class="r">Cost/unit</th>
                                <th class="r">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in _do.Lines)
                            {
                                <tr>
                                    <td class="prod">
                                        <span class="pn">@l.ProductName</span>
                                        <span class="sku">@l.VariantSku</span>
                                    </td>
                                    <td class="r mono">@l.OrderedQuantity</td>
                                    <td class="c">
                                        <span class="recv @(l.QuantityDelivered == 0 ? "none" : l.QuantityDelivered >= l.OrderedQuantity ? "full" : "part")">@l.QuantityDelivered</span>
                                    </td>
                                    <td class="r mono">@l.UnitCost.ToString("N2")</td>
                                    <td class="r mono total">@l.LineCost.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="r gt-l">Total</td>
                                <td class="r grand">@_do.Lines.Sum(l => l.LineCost).ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </section>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private DeliveryOrderDto? _do;
    private bool _loading = true;
    private bool _posting;
    private string? _error;

    protected override Task OnParametersSetAsync() => LoadAsync();
    private async Task LoadAsync()
    {
        _loading = true;
        _do = await Do.GetByIdAsync(Id);
        _loading = false;
    }

    private async Task PostAsync()
    {
        if (!await Swal.ConfirmAsync("Post Delivery Order?", "Stock will be reduced and COGS recorded; this cannot be undone.", "Yes, Post")) return;
        _error = null; _posting = true;
        try { await Do.PostAsync(Id); await LoadAsync(); }
        catch (FluentValidation.ValidationException ex) { _error = string.Join("; ", ex.Errors.Select(e => e.ErrorMessage)); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _posting = false; }
    }

    private static string StatusClass(string status) => status switch
    {
        "Draft" => "b-draft",
        "Posted" => "b-done",
        _ => "b-dark"
    };
}
