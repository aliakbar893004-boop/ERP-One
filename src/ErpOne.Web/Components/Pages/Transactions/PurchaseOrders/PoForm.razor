@page "/transactions/purchase-orders/new"
@page "/transactions/purchase-orders/{Id:int}/edit"
@attribute [Authorize]
@rendermode InteractiveServer
@using FluentValidation
@using ErpOne.Application.PurchaseOrders
@using ErpOne.Application.Suppliers
@using ErpOne.Application.Warehouses
@using ErpOne.Application.Taxes
@using ErpOne.Web.Authorization
@inject IPurchaseOrderService PoService
@inject ISupplierService SupplierService
@inject IWarehouseService WarehouseService
@inject ITaxService TaxService
@inject IAuthorizationService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@Title</PageTitle>

<div class="pf">

    <div class="pf-top">
        <div class="crumbs">
            <a href="/transactions/purchase-orders">Transactions</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/transactions/purchase-orders">Purchase Orders</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(Id is null ? "New" : "Edit")</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_notFound)
    {
        <div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> Purchase order not found or not a draft.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="pf-layout">

            <!-- ── LEFT: section navigator ─────────────────────────── -->
            <aside class="pf-nav">
                <div class="prog">
                    <div class="lbl"><span>Required</span><span>@ReqFilled / @ReqTotal</span></div>
                    <div class="track"><div class="fill" style="width:@(ReqFilled * 100 / ReqTotal)%"></div></div>
                </div>
                <button type="button" class="nlink @(_activeSection == "sec-info" ? "on" : "")"
                        @onclick='() => ScrollTo("sec-info")'>
                    <span class="ic"><i class="bi bi-receipt"></i></span> Information
                    @if (InfoComplete)
                    {
                        <i class="bi bi-check-circle-fill ck"></i>
                    }
                </button>
                <button type="button" class="nlink @(_activeSection == "sec-items" ? "on" : "")"
                        @onclick='() => ScrollTo("sec-items")'>
                    <span class="ic"><i class="bi bi-box-seam"></i></span> Items
                    <span class="badge-n">@ValidLineCount</span>
                </button>
            </aside>

            <!-- ── RIGHT: form panels ──────────────────────────────── -->
            <main class="pf-main">

                <!-- PO information -->
                <section id="sec-info" class="card">
                    <div class="card-h">
                        <span class="hd-ic"><i class="bi bi-receipt"></i></span>
                        <div class="hd-tx">
                            <h2>Purchase order information</h2>
                            <p>Supplier, destination warehouse, and date.</p>
                        </div>
                    </div>
                    <div class="card-b">
                        <div class="grid">
                            <div class="c4">
                                <label class="fl">Supplier <span class="req">*</span></label>
                                <select class="ctl sel" @bind="_supplierId">
                                    <option value="0">— select supplier —</option>
                                    @foreach (var s in _suppliers)
                                    {
                                        <option value="@s.Id">@s.Code — @s.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="c4">
                                <label class="fl">Destination Warehouse <span class="req">*</span></label>
                                <select class="ctl sel" @bind="_warehouseId">
                                    <option value="0">— select warehouse —</option>
                                    @foreach (var w in _warehouses)
                                    {
                                        <option value="@w.Id">@w.Code — @w.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="c2">
                                <label class="fl">Date <span class="req">*</span></label>
                                <input type="date" class="ctl" @bind="_orderDate" />
                            </div>
                            <div class="c2">
                                <label class="fl">Expected Date</label>
                                <input type="date" class="ctl" @bind="_expectedDate" />
                            </div>
                            <div class="c12">
                                <label class="fl">Notes</label>
                                <textarea class="ctl" rows="2" maxlength="500" placeholder="Optional…" @bind="_notes"></textarea>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Line items -->
                <section id="sec-items" class="card">
                    <div class="card-h">
                        <span class="hd-ic"><i class="bi bi-box-seam"></i></span>
                        <div class="hd-tx">
                            <h2>Items</h2>
                            <p>Ordered products, price, discount, and tax per line.</p>
                        </div>
                        <div class="hd-act">
                            <button type="button" class="btn btn-soft" @onclick="AddRow"><i class="bi bi-plus-lg"></i> Add Row</button>
                        </div>
                    </div>
                    <div class="card-b">
                        <div class="table-responsive">
                            <table class="items">
                                <thead>
                                    <tr>
                                        <th style="min-width:220px">Product (Variant)</th>
                                        <th style="width:90px">Qty</th>
                                        <th style="width:130px">Price</th>
                                        <th style="width:90px">Disc %</th>
                                        <th style="width:150px">Tax</th>
                                        <th class="text-end" style="width:130px">Subtotal</th>
                                        <th style="width:40px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _rows)
                                    {
                                        <tr>
                                            <td>
                                                <select class="ctl sel ctl-sm" value="@row.VariantId"
                                                        @onchange="e => OnVariantChanged(row, e.Value?.ToString())">
                                                    <option value="0">— select —</option>
                                                    @foreach (var v in _variants)
                                                    {
                                                        <option value="@v.VariantId">@v.Sku — @v.ProductName</option>
                                                    }
                                                </select>
                                            </td>
                                            <td><input type="number" min="1" class="ctl ctl-sm mono text-end" @bind="row.Quantity" /></td>
                                            <td><input type="number" min="0" step="0.01" class="ctl ctl-sm mono text-end" @bind="row.UnitPrice" /></td>
                                            <td><input type="number" min="0" max="100" step="0.01" class="ctl ctl-sm mono text-end" @bind="row.DiscountPercent" /></td>
                                            <td>
                                                <select class="ctl sel ctl-sm" @bind="row.TaxId">
                                                    <option value="">no tax</option>
                                                    @foreach (var t in _taxes)
                                                    {
                                                        <option value="@t.Id">@t.Name (@t.Rate%)</option>
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-end sub">@LineTotal(row).ToString("N2")</td>
                                            <td><button type="button" class="vr-del" title="Remove" @onclick="() => _rows.Remove(row)"><i class="bi bi-trash3"></i></button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (_rows.Count == 0)
                        {
                            <div class="hint"><i class="bi bi-info-circle me-1"></i>No rows yet. Click “Add Row” to add an item.</div>
                        }
                    </div>
                </section>

            </main>
        </div>

        <div class="pf-footer">
            <div class="in">
                <span class="note"><span class="req">*</span> required fields</span>
                <span class="gt">Grand Total: <b>@GrandTotal().ToString("N2")</b></span>
                <a class="btn btn-ghost" href="/transactions/purchase-orders"><i class="bi bi-x-lg"></i> Cancel</a>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    else
                    {
                        <i class="bi bi-check2"></i>
                    }
                    Save Draft
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private sealed class Row
    {
        public int VariantId { get; set; }
        public int Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; }
        public decimal DiscountPercent { get; set; }
        public int? TaxId { get; set; }
    }

    private IReadOnlyList<SupplierDto> _suppliers = [];
    private IReadOnlyList<WarehouseDto> _warehouses = [];
    private IReadOnlyList<TaxDto> _taxes = [];
    private IReadOnlyList<PurchaseOrderVariantOptionDto> _variants = [];
    private readonly List<Row> _rows = [];

    private int _supplierId, _warehouseId;
    private DateTime _orderDate = DateTime.Today;
    private DateTime? _expectedDate;
    private string? _notes;
    private bool _loading = true, _saving, _notFound;
    private string? _error;

    private string Title => Id is null ? "Add Purchase Order" : "Edit Purchase Order";

    // Atlas nav: required-field progress (Supplier + Warehouse + ≥1 item line)
    private const int ReqTotal = 3;
    private int ReqFilled => (_supplierId > 0 ? 1 : 0) + (_warehouseId > 0 ? 1 : 0) + (ValidLineCount > 0 ? 1 : 0);
    private bool InfoComplete => _supplierId > 0 && _warehouseId > 0;
    private int ValidLineCount => _rows.Count(r => r.VariantId > 0);

    // Atlas nav: active section highlight + smooth scroll
    private string _activeSection = "sec-info";

    private async Task ScrollTo(string id)
    {
        _activeSection = id;
        await JS.InvokeVoidAsync("pfScrollTo", id);
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        var perm = Id is null ? AppMenus.Perm("transactions.purchase-orders", "create")
                              : AppMenus.Perm("transactions.purchase-orders", "edit");
        if (!(await Auth.AuthorizeAsync(state.User, perm)).Succeeded)
        {
            Nav.NavigateTo("/transactions/purchase-orders");
            return;
        }

        _suppliers = await SupplierService.GetAllAsync();
        _warehouses = await WarehouseService.GetAllAsync();
        _taxes = await TaxService.GetAllAsync();
        _variants = await PoService.SearchVariantsAsync(null);

        if (Id is int id)
        {
            var po = await PoService.GetByIdAsync(id);
            if (po is null || po.Status != "Draft") { _notFound = true; }
            else
            {
                _supplierId = po.SupplierId; _warehouseId = po.WarehouseId;
                _orderDate = po.OrderDate; _expectedDate = po.ExpectedDate; _notes = po.Notes;
                foreach (var l in po.Lines)
                    _rows.Add(new Row { VariantId = l.ProductVariantId, Quantity = l.Quantity, UnitPrice = l.UnitPrice, DiscountPercent = l.DiscountPercent, TaxId = l.TaxId });
            }
        }
        else
        {
            AddRow();
        }
        _loading = false;
    }

    private void AddRow() => _rows.Add(new Row());

    private void OnVariantChanged(Row row, string? value)
    {
        row.VariantId = int.TryParse(value, out var id) ? id : 0;
        var v = _variants.FirstOrDefault(x => x.VariantId == row.VariantId);
        if (v is not null && row.UnitPrice == 0) row.UnitPrice = v.CostPrice; // suggested price = cost price
    }

    private decimal LineTotal(Row r)
    {
        var sub = Math.Round(r.Quantity * r.UnitPrice, 2, MidpointRounding.AwayFromZero);
        var disc = Math.Round(sub * r.DiscountPercent / 100m, 2, MidpointRounding.AwayFromZero);
        var rate = r.TaxId is { } tid ? _taxes.FirstOrDefault(t => t.Id == tid)?.Rate ?? 0m : 0m;
        var tax = Math.Round((sub - disc) * rate / 100m, 2, MidpointRounding.AwayFromZero);
        return sub - disc + tax;
    }

    private decimal GrandTotal() => _rows.Sum(LineTotal);

    private async Task SaveAsync()
    {
        _error = null;
        var lines = _rows.Where(r => r.VariantId > 0)
            .Select(r => new PurchaseOrderLineRequest(r.VariantId, r.Quantity, r.UnitPrice, r.DiscountPercent, r.TaxId))
            .ToList();
        if (lines.Count == 0) { _error = "Select at least one line item with a product."; return; }

        _saving = true;
        try
        {
            if (Id is int id)
                await PoService.UpdateAsync(id, new UpdatePurchaseOrderRequest(_supplierId, _warehouseId, _orderDate, _expectedDate, _notes, lines));
            else
                await PoService.CreateAsync(new CreatePurchaseOrderRequest(_supplierId, _warehouseId, _orderDate, _expectedDate, _notes, lines));
            Nav.NavigateTo("/transactions/purchase-orders");
        }
        catch (ValidationException ex)
        {
            _error = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        finally { _saving = false; }
    }
}
