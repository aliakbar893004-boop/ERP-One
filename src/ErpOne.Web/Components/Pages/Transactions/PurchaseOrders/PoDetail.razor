@page "/transactions/purchase-orders/{Id:int}"
@attribute [Authorize(Policy = "transactions.purchase-orders.index")]
@rendermode InteractiveServer
@using FluentValidation
@using ErpOne.Application.Approvals
@using ErpOne.Application.PurchaseOrders
@inject IPurchaseOrderService PoService
@inject IAuthorizationService Auth
@inject NavigationManager Nav
@inject SwalService Swal

<PageTitle>@(_po?.PoNumber ?? "Purchase Order")</PageTitle>

<div class="pf pf-detail">

    <div class="pf-top">
        <div class="crumbs">
            <a href="/transactions/purchase-orders">Transactions</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/transactions/purchase-orders">Purchase Orders</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(_po?.PoNumber ?? "Detail")</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_po is null)
    {
        <div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> Purchase order not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="pd-head">
            <h1>@_po.PoNumber</h1>
            <span class="badge @StatusClass(_po.Status)">@_po.Status</span>
            <div class="actions">
                @if (_po.Status == "Draft")
                {
                    <a class="btn btn-line" href="@($"/transactions/purchase-orders/{_po.Id}/edit")"><i class="bi bi-pencil"></i> Edit</a>
                    <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@_busy"><i class="bi bi-send"></i> Submit</button>
                    <button class="btn btn-line" @onclick="CancelAsync" disabled="@_busy">Cancel</button>
                }
                else if (_po.Status == "PendingApproval")
                {
                    @if (_canApprove)
                    {
                        <button class="btn btn-ok" @onclick="ApproveAsync" disabled="@_busy"><i class="bi bi-check2-circle"></i> Approve</button>
                        <button class="btn btn-danger" @onclick="() => _showReject = true" disabled="@_busy"><i class="bi bi-x-circle"></i> Reject</button>
                    }
                    <button class="btn btn-line" @onclick="CancelAsync" disabled="@_busy">Cancel</button>
                }
                else if (_po.Status == "Confirmed" || _po.Status == "PartiallyReceived")
                {
                    <AuthorizeView Policy="transactions.goods-receipts.create">
                        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo($"/transactions/goods-receipts/new?poId={_po.Id}")' disabled="@_busy"><i class="bi bi-box-arrow-in-down"></i> Create GRN</button>
                    </AuthorizeView>
                    @if (_po.Status == "PartiallyReceived")
                    {
                        <AuthorizeView Policy="transactions.purchase-orders.close">
                            <button class="btn btn-line" @onclick="ClosePoAsync" disabled="@_busy">Close PO</button>
                        </AuthorizeView>
                    }
                }
            </div>
        </div>

        @if (_showReject)
        {
            <div class="card danger">
                <div class="card-h">
                    <span class="hd-ic dng"><i class="bi bi-x-octagon"></i></span>
                    <h2>Rejection Reason</h2>
                </div>
                <div class="card-b">
                    <textarea class="ctl" rows="2" maxlength="500" @bind="_rejectReason" placeholder="Write the rejection reason..."></textarea>
                    <div class="row-end">
                        <button class="btn btn-line btn-sm" @onclick="() => { _showReject = false; _rejectReason = string.Empty; }">Cancel</button>
                        <button class="btn btn-danger btn-sm" @onclick="RejectAsync" disabled="@_busy">Confirm Reject</button>
                    </div>
                </div>
            </div>
        }

        <div class="pd-layout">
            <div>
                <section class="card">
                    <div class="card-h">
                        <span class="hd-ic"><i class="bi bi-receipt"></i></span>
                        <h2>Information</h2>
                    </div>
                    <div class="card-b">
                        <div class="info-grid">
                            <div class="info-cell">
                                <span class="k"><i class="bi bi-building"></i> Supplier</span>
                                <span class="v">@_po.SupplierName</span>
                            </div>
                            <div class="info-cell">
                                <span class="k"><i class="bi bi-box-seam"></i> Destination Warehouse</span>
                                <span class="v">@_po.WarehouseName</span>
                            </div>
                            <div class="info-cell">
                                <span class="k"><i class="bi bi-calendar3"></i> Order Date</span>
                                <span class="v">@_po.OrderDate.ToString("dd MMM yyyy")</span>
                            </div>
                            <div class="info-cell">
                                <span class="k"><i class="bi bi-calendar-check"></i> Expected Arrival</span>
                                <span class="v @(_po.ExpectedDate is null ? "muted-v" : "")">@(_po.ExpectedDate?.ToString("dd MMM yyyy") ?? "—")</span>
                            </div>
                            <div class="info-cell wide">
                                <span class="k"><i class="bi bi-sticky"></i> Notes</span>
                                <span class="v @(string.IsNullOrEmpty(_po.Notes) ? "muted-v" : "")">@(_po.Notes ?? "—")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(_po.RejectionNote))
                            {
                                <div class="info-cell wide reject">
                                    <span class="k"><i class="bi bi-x-octagon"></i> Rejection Reason</span>
                                    <span class="v">@_po.RejectionNote</span>
                                </div>
                            }
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-h">
                        <span class="hd-ic"><i class="bi bi-box-seam"></i></span>
                        <h2>Items</h2>
                    </div>
                    <div class="card-b">
                        <div class="table-responsive">
                            <table class="items">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th class="r">Qty</th>
                                        <th class="c">Received</th>
                                        <th class="r">Price</th>
                                        <th class="r">Disc</th>
                                        <th class="r">Tax</th>
                                        <th class="r">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var l in _po.Lines)
                                    {
                                        <tr>
                                            <td class="prod">
                                                <span class="pn">@l.ProductName</span>
                                                <span class="sku">@l.VariantSku</span>
                                            </td>
                                            <td class="r mono">@l.Quantity</td>
                                            <td class="c">
                                                <span class="recv @(l.ReceivedQuantity == 0 ? "none" : l.ReceivedQuantity >= l.Quantity ? "full" : "part")">
                                                    @l.ReceivedQuantity / @l.Quantity
                                                </span>
                                            </td>
                                            <td class="r mono">@l.UnitPrice.ToString("N2")</td>
                                            <td class="r mono @(l.LineDiscount == 0 ? "zero" : "")">@(l.LineDiscount == 0 ? "—" : l.LineDiscount.ToString("N2"))</td>
                                            <td class="r mono @(l.LineTax == 0 ? "zero" : "")">@(l.LineTax == 0 ? "—" : l.LineTax.ToString("N2"))</td>
                                            <td class="r mono total">@l.LineTotal.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="6" class="r gt-l">Grand Total (@_po.Currency)</td>
                                        <td class="r grand">@_po.GrandTotal.ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </section>
            </div>

            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-diagram-3"></i></span>
                    <h2>Approval</h2>
                </div>
                <div class="card-b">
                    @if (_steps.Count == 0)
                    {
                        <p class="muted">No approval steps yet.</p>
                    }
                    else
                    {
                        <ul class="tl">
                            @foreach (var s in _steps)
                            {
                                <li>
                                    <span class="dot @StepDot(s.Status)"><i class="bi @StepIcon(s.Status)"></i></span>
                                    <div>
                                        <div class="ti">Level @s.StepOrder — @s.RoleName</div>
                                        <div class="meta">
                                            @s.Status
                                            @if (s.ActedByName is not null) { <text> · @s.ActedByName</text> }
                                            @if (s.ActedAt is not null) { <text> · @s.ActedAt.Value.ToString("dd MMM HH:mm")</text> }
                                        </div>
                                        @if (!string.IsNullOrEmpty(s.Note)) { <div class="note">@s.Note</div> }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </section>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private PurchaseOrderDto? _po;
    private IReadOnlyList<ApprovalStepDto> _steps = [];
    private bool _loading = true, _busy, _canApprove, _showReject;
    private string _rejectReason = string.Empty;
    private string? _error;
    private System.Security.Claims.ClaimsPrincipal _user = default!;

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthStateTask).User;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _po = await PoService.GetByIdAsync(Id);
        _steps = _po is null ? [] : await PoService.GetApprovalStepsAsync(Id);
        _canApprove = await EvaluateCanApproveAsync();
        _loading = false;
    }

    private async Task<bool> EvaluateCanApproveAsync()
    {
        if (_po is null || _po.Status != "PendingApproval") return false;
        if (!(await Auth.AuthorizeAsync(_user, "transactions.purchase-orders.approve")).Succeeded) return false;
        // not the creator
        if (string.Equals(_po.CreatedBy, _user.Identity?.Name, StringComparison.OrdinalIgnoreCase)) return false;
        // holds the role on the current Pending step
        var current = _steps.FirstOrDefault(s => s.Status == "Pending");
        return current is not null && _user.IsInRole(current.RoleName);
    }

    private async Task SubmitAsync() => await RunAsync(() => PoService.SubmitAsync(Id), "PO submitted");
    private async Task CancelAsync()
    {
        if (!await Swal.ConfirmAsync("Cancel PO?", "The PO will be marked Cancelled.")) return;
        await RunAsync(() => PoService.CancelAsync(Id), "PO cancelled");
    }
    private async Task ApproveAsync() =>
        await RunAsync(() => PoService.ApproveAsync(Id, _user.Identity?.Name ?? "", _user.IsInRole), "PO approved");

    private async Task RejectAsync()
    {
        if (string.IsNullOrWhiteSpace(_rejectReason)) { _error = "Rejection reason is required."; return; }
        var reason = _rejectReason;
        _showReject = false;
        _rejectReason = string.Empty;
        await RunAsync(() => PoService.RejectAsync(Id, _user.Identity?.Name ?? "", _user.IsInRole, reason), "PO rejected, returned to Draft");
    }

    private async Task ClosePoAsync()
    {
        if (!await Swal.ConfirmAsync("Close this PO?", "Remaining qty can no longer be received.")) return;
        await RunAsync(() => PoService.CloseAsync(Id), "PO closed");
    }

    private async Task RunAsync(Func<Task> action, string okMsg)
    {
        _error = null; _busy = true;
        try
        {
            await action();
            await LoadAsync();
            await Swal.ToastAsync("success", okMsg);
        }
        catch (ValidationException ex) { _error = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private static string StatusClass(string s) => s switch
    {
        "Draft" => "b-draft",
        "PendingApproval" => "b-warn",
        "Confirmed" => "b-ok",
        "PartiallyReceived" => "b-info",
        "Received" => "b-done",
        "Closed" => "b-closed",
        "Rejected" => "b-danger",
        "Cancelled" => "b-cancel",
        _ => "b-dark"
    };
    private static string StepIcon(string s) => s switch
    {
        "Approved" => "bi-check-lg", "Rejected" => "bi-x-lg", _ => "bi-clock"
    };
    private static string StepDot(string s) => s switch
    {
        "Approved" => "ok", "Rejected" => "no", _ => "wait"
    };
}
