@page "/transactions/goods-receipts/{Id:int}"
@attribute [Authorize(Policy = "transactions.goods-receipts.index")]
@rendermode InteractiveServer
@using FluentValidation
@using ErpOne.Application.GoodsReceipts
@inject IGoodsReceiptService Grn
@inject NavigationManager Nav
@inject SwalService Swal

<PageTitle>@(_grn?.GrnNumber ?? "Goods Receipt")</PageTitle>

<div class="pf pf-detail">

    <div class="pf-top">
        <div class="crumbs">
            <a href="/transactions/goods-receipts">Transactions</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/transactions/goods-receipts">Goods Receipts</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(_grn?.GrnNumber ?? "Detail")</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_grn is null)
    {
        <div class="pf-alert warn"><i class="bi bi-exclamation-triangle"></i> Goods receipt not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="pd-head">
            <h1>@_grn.GrnNumber</h1>
            <span class="badge @StatusClass(_grn.Status)">@_grn.Status</span>
            <div class="actions">
                @if (_grn.Status == "Draft")
                {
                    <AuthorizeView Policy="transactions.goods-receipts.edit">
                        <Authorized>
                            <a class="btn btn-line" href="@($"/transactions/goods-receipts/{_grn.Id}/edit")"><i class="bi bi-pencil"></i> Edit</a>
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Policy="transactions.goods-receipts.post">
                        <Authorized>
                            <button class="btn btn-primary" @onclick="PostAsync" disabled="@_posting"><i class="bi bi-check2-circle"></i> Post</button>
                        </Authorized>
                    </AuthorizeView>
                }
            </div>
        </div>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-receipt"></i></span>
                <h2>Information</h2>
            </div>
            <div class="card-b">
                <div class="info-grid">
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-receipt"></i> GRN #</span>
                        <span class="v"><span class="grn-no">@_grn.GrnNumber</span></span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-file-earmark-text"></i> PO #</span>
                        <span class="v"><a href="/transactions/purchase-orders/@_grn.PurchaseOrderId">@_grn.PoNumber</a></span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-building"></i> Supplier</span>
                        <span class="v">@_grn.SupplierName</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-box-seam"></i> Warehouse</span>
                        <span class="v">@_grn.WarehouseName</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-calendar3"></i> Receipt Date</span>
                        <span class="v">@_grn.ReceiptDate.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-clock"></i> Created</span>
                        <span class="v">@_grn.CreatedAt.ToString("dd MMM yyyy HH:mm")@(string.IsNullOrEmpty(_grn.CreatedBy) ? "" : " · " + _grn.CreatedBy)</span>
                    </div>
                    <div class="info-cell wide">
                        <span class="k"><i class="bi bi-sticky"></i> Notes</span>
                        <span class="v @(string.IsNullOrEmpty(_grn.Notes) ? "muted-v" : "")">@(_grn.Notes ?? "—")</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-box-seam"></i></span>
                <h2>Items</h2>
            </div>
            <div class="card-b">
                <div class="table-responsive">
                    <table class="items">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="r">Ordered</th>
                                <th class="c">Received</th>
                                <th class="r">Cost/unit</th>
                                <th class="r">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in _grn.Lines)
                            {
                                <tr>
                                    <td class="prod">
                                        <span class="pn">@l.ProductName</span>
                                        <span class="sku">@l.VariantSku</span>
                                    </td>
                                    <td class="r mono">@l.OrderedQuantity</td>
                                    <td class="c">
                                        <span class="recv @(l.QuantityReceived == 0 ? "none" : l.QuantityReceived >= l.OrderedQuantity ? "full" : "part")">@l.QuantityReceived</span>
                                    </td>
                                    <td class="r mono">@l.UnitCost.ToString("N2")</td>
                                    <td class="r mono total">@l.LineCost.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="r gt-l">Total</td>
                                <td class="r grand">@_grn.Lines.Sum(l => l.LineCost).ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </section>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private GoodsReceiptDto? _grn;
    private bool _loading = true;
    private bool _posting;
    private string? _error;

    protected override Task OnParametersSetAsync() => LoadAsync();
    private async Task LoadAsync()
    {
        _loading = true;
        _grn = await Grn.GetByIdAsync(Id);
        _loading = false;
    }

    private async Task PostAsync()
    {
        if (!await Swal.ConfirmAsync("Post Goods Receipt?", "Stock & cost will be updated and cannot be undone.", "Yes, Post")) return;
        _error = null; _posting = true;
        try { await Grn.PostAsync(Id); await LoadAsync(); }
        catch (FluentValidation.ValidationException ex) { _error = string.Join("; ", ex.Errors.Select(e => e.ErrorMessage)); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _posting = false; }
    }

    private static string StatusClass(string status) => status switch
    {
        "Draft" => "b-draft",
        "Posted" => "b-done",
        _ => "b-dark"
    };
}
