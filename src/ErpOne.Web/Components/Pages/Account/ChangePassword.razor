@page "/account/change-password"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>Change Password</PageTitle>

<div class="cp-wrap">
    <div class="cp-card">
        <div class="cp-head">
            <span class="cp-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="15" r="4"/><line x1="10.85" y1="12.15" x2="19" y2="4"/><line x1="18" y1="5" x2="20" y2="7"/><line x1="15" y1="8" x2="17" y2="10"/></svg>
            </span>
            <div>
                <div class="cp-kicker">Security</div>
                <h1 class="cp-title">Change password</h1>
            </div>
        </div>
        <p class="cp-sub">Use something memorable but hard to guess.</p>

        @if (_success)
        {
            <div class="cp-alert cp-ok">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <div>
                    <b>Password changed successfully!</b>
                    <span>Use your new password at the next sign-in.</span>
                </div>
            </div>
            <div class="cp-actions">
                <a class="cp-btn" href="/">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Back to home
                </a>
            </div>
        }
        else
        {
            @if (_error is not null)
            {
                <div class="cp-alert cp-bad">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    <span>@_error</span>
                </div>
            }

            <div class="cp-fields">
                <div class="af-field">
                    <label>Current password</label>
                    <div class="pw">
                        <div class="af-inp">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <input class="af-input" type="@(_show0 ? "text" : "password")" @bind="_current" placeholder="Enter current password" />
                        </div>
                        <button class="cp-eye" type="button" @onclick="() => _show0 = !_show0" title="@(_show0 ? "Hide" : "Show")" aria-label="Toggle password visibility">
                            @if (_show0) { @EyeOff } else { @Eye }
                        </button>
                    </div>
                </div>

                <div class="af-field">
                    <label>New password</label>
                    <div class="pw">
                        <div class="af-inp">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <input class="af-input" type="@(_show1 ? "text" : "password")" @bind="_newPwd" placeholder="At least 6 characters" />
                        </div>
                        <button class="cp-eye" type="button" @onclick="() => _show1 = !_show1" title="@(_show1 ? "Hide" : "Show")" aria-label="Toggle password visibility">
                            @if (_show1) { @EyeOff } else { @Eye }
                        </button>
                    </div>
                </div>

                <div class="af-field">
                    <label>Confirm new password</label>
                    <div class="pw">
                        <div class="af-inp">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <input class="af-input" type="@(_show2 ? "text" : "password")" @bind="_confirm" placeholder="Repeat new password" />
                        </div>
                        <button class="cp-eye" type="button" @onclick="() => _show2 = !_show2" title="@(_show2 ? "Hide" : "Show")" aria-label="Toggle password visibility">
                            @if (_show2) { @EyeOff } else { @Eye }
                        </button>
                    </div>
                </div>
            </div>

            <div class="cp-actions">
                <a class="cp-ghost" href="/">Cancel</a>
                <button class="cp-btn" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="cp-spin" role="status"></span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    }
                    Save changes
                </button>
            </div>
        }
    </div>
</div>

@code {
    private string? _current;
    private string? _newPwd;
    private string? _confirm;
    private bool _show0, _show1, _show2;
    private bool _saving, _success;
    private string? _error;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private static readonly RenderFragment Eye = builder =>
    {
        builder.AddMarkupContent(0, "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>");
    };

    private static readonly RenderFragment EyeOff = builder =>
    {
        builder.AddMarkupContent(0, "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24\"/><line x1=\"1\" y1=\"1\" x2=\"23\" y2=\"23\"/></svg>");
    };

    private async Task SaveAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_current))  { _error = "Current password is required."; return; }
        if (string.IsNullOrWhiteSpace(_newPwd))   { _error = "New password is required."; return; }
        if (_newPwd != _confirm)                   { _error = "Password confirmation does not match."; return; }

        _saving = true;
        try
        {
            var state = await AuthStateTask;
            var user  = await UserManager.GetUserAsync(state.User);
            if (user is null) { _error = "User not found."; return; }

            var result = await UserManager.ChangePasswordAsync(user, _current, _newPwd);
            if (result.Succeeded)
            {
                _success = true;
            }
            else
            {
                _error = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        finally
        {
            _saving = false;
        }
    }
}
