@page "/account/change-password"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>Change Password</PageTitle>

<div class="cp-wrap">
    <div class="cp-card">

        <div class="cp-header mb-4">
            <div class="cp-icon-wrap">
                <i class="bi bi-key-fill cp-icon"></i>
            </div>
            <div>
                <h5 class="mb-0 fw-semibold">Change Password</h5>
                <p class="text-muted small mb-0">Make sure your new password is easy to remember but hard to guess.</p>
            </div>
        </div>

        @if (_success)
        {
            <div class="alert alert-success d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                    <div class="fw-semibold">Password changed successfully!</div>
                    <div class="small">Use your new password at the next sign-in.</div>
                </div>
            </div>
            <div class="d-flex gap-2 justify-content-end mt-3">
                <a class="btn btn-primary px-4" href="/">
                    <i class="bi bi-house-door-fill me-1"></i>Back to Home
                </a>
            </div>
        }
        else
        {
            @if (_error is not null)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@_error</span>
                </div>
            }

            <div class="mb-3">
                <label class="form-label lbl-required">Current Password</label>
                <div class="input-group">
                    <input class="form-control" type="@(_show0 ? "text" : "password")"
                           @bind="_current" placeholder="Enter current password" />
                    <button class="btn btn-outline-secondary px-3" type="button"
                            @onclick="() => _show0 = !_show0"
                            title="@(_show0 ? "Hide" : "Show")">
                        <i class="bi @(_show0 ? "bi-eye-slash-fill" : "bi-eye-fill")"></i>
                    </button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label lbl-required">New Password</label>
                <div class="input-group">
                    <input class="form-control" type="@(_show1 ? "text" : "password")"
                           @bind="_newPwd" placeholder="At least 6 characters" />
                    <button class="btn btn-outline-secondary px-3" type="button"
                            @onclick="() => _show1 = !_show1"
                            title="@(_show1 ? "Hide" : "Show")">
                        <i class="bi @(_show1 ? "bi-eye-slash-fill" : "bi-eye-fill")"></i>
                    </button>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label lbl-required">Confirm New Password</label>
                <div class="input-group">
                    <input class="form-control" type="@(_show2 ? "text" : "password")"
                           @bind="_confirm" placeholder="Repeat new password" />
                    <button class="btn btn-outline-secondary px-3" type="button"
                            @onclick="() => _show2 = !_show2"
                            title="@(_show2 ? "Hide" : "Show")">
                        <i class="bi @(_show2 ? "bi-eye-slash-fill" : "bi-eye-fill")"></i>
                    </button>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-primary btn-sm px-3" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    else
                    {
                        <i class="bi bi-floppy2-fill me-1"></i>
                    }
                    Save
                </button>
                <a class="btn btn-outline-secondary btn-sm" href="/">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </a>
            </div>
        }

    </div>
</div>

@code {
    private string? _current;
    private string? _newPwd;
    private string? _confirm;
    private bool _show0, _show1, _show2;
    private bool _saving, _success;
    private string? _error;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private async Task SaveAsync()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_current))  { _error = "Current password is required."; return; }
        if (string.IsNullOrWhiteSpace(_newPwd))   { _error = "New password is required."; return; }
        if (_newPwd != _confirm)                   { _error = "Password confirmation does not match."; return; }

        _saving = true;
        try
        {
            var state = await AuthStateTask;
            var user  = await UserManager.GetUserAsync(state.User);
            if (user is null) { _error = "User not found."; return; }

            var result = await UserManager.ChangePasswordAsync(user, _current, _newPwd);
            if (result.Succeeded)
            {
                _success = true;
            }
            else
            {
                _error = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        finally
        {
            _saving = false;
        }
    }
}
