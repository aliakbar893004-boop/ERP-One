@page "/master/payment-methods/new"
@page "/master/payment-methods/{Id:int}/edit"
@attribute [Authorize]
@rendermode InteractiveServer
@using FluentValidation
@inject IPaymentMethodService PaymentMethodService
@inject IAuthorizationService Auth
@inject NavigationManager Nav

<PageTitle>@Title</PageTitle>

<div class="cf">

    <div class="cf-top">
        <div class="crumbs">
            <a href="/master/payment-methods">Master</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/master/payment-methods">Payment Methods</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(Id is null ? "New" : "Edit")</span>
        </div>
        <h1>@Title</h1>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_notFound)
    {
        <div class="cf-alert warn"><i class="bi bi-exclamation-triangle"></i> Payment method not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="cf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="cf-wrap">
            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-credit-card-2-front"></i></span>
                    <div class="hd-tx">
                        <h2>Payment method information</h2>
                        <p>How customers can pay at checkout.</p>
                    </div>
                </div>
                <div class="card-b">
                    <div class="grid">
                        <div class="f c4">
                            <label class="fl">Code <span class="req">*</span></label>
                            <input class="ctl mono up @(_codeError is not null ? "bad" : "")"
                                   placeholder="e.g. QRIS" maxlength="20"
                                   @bind="_code" @bind:event="oninput" />
                            @if (_codeError is not null)
                            {
                                <div class="err-txt">@_codeError</div>
                            }
                        </div>
                        <div class="f c8">
                            <label class="fl">Name <span class="req">*</span></label>
                            <input class="ctl @(_nameError is not null ? "bad" : "")"
                                   placeholder="e.g. QRIS" maxlength="100"
                                   @bind="_name" @bind:event="oninput" />
                            @if (_nameError is not null)
                            {
                                <div class="err-txt">@_nameError</div>
                            }
                        </div>
                        <div class="f c4">
                            <label class="fl">Type <span class="req">*</span></label>
                            <select class="ctl @(_typeError is not null ? "bad" : "")" @bind="_type">
                                @foreach (var t in Enum.GetValues<PaymentType>())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                            @if (_typeError is not null)
                            {
                                <div class="err-txt">@_typeError</div>
                            }
                        </div>
                        <div class="f c8">
                            <label class="fl">Status</label>
                            <label class="tgl">
                                <input type="checkbox" @bind="_isActive" />
                                <span class="sw"></span>
                                <span class="tx">Active<small>Selectable at checkout</small></span>
                            </label>
                        </div>
                    </div>
                </div>
            </section>

            <div class="pf-footer">
                <div class="in">
                    <span class="note"><span class="req">*</span> required fields</span>
                    <a class="btn btn-ghost" href="/master/payment-methods"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        else
                        {
                            <i class="bi bi-check2"></i>
                        }
                        Save payment method
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private string _code = string.Empty;
    private string _name = string.Empty;
    private PaymentType _type = PaymentType.Tunai;
    private bool _isActive = true;
    private bool _loading = true, _saving, _notFound;
    private string? _error, _codeError, _nameError, _typeError;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string Title => Id is null ? "Add Payment Method" : "Edit Payment Method";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        var perm = Id is null
            ? AppMenus.Perm("master.payment-methods", "create")
            : AppMenus.Perm("master.payment-methods", "edit");

        if (!(await Auth.AuthorizeAsync(state.User, perm)).Succeeded)
        {
            Nav.NavigateTo("/master/payment-methods");
            return;
        }

        if (Id is int id)
        {
            var pm = await PaymentMethodService.GetByIdAsync(id);
            if (pm is null)
                _notFound = true;
            else
            {
                _code = pm.Code;
                _name = pm.Name;
                _type = pm.Type;
                _isActive = pm.IsActive;
            }
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        _error = _codeError = _nameError = _typeError = null;
        _saving = true;

        try
        {
            if (Id is int id)
                await PaymentMethodService.UpdateAsync(id, new UpdatePaymentMethodRequest(_code, _name, _type, _isActive));
            else
                await PaymentMethodService.CreateAsync(new CreatePaymentMethodRequest(_code, _name, _type, _isActive));

            Nav.NavigateTo("/master/payment-methods");
        }
        catch (ValidationException ex)
        {
            foreach (var e in ex.Errors)
            {
                if (e.PropertyName == nameof(CreatePaymentMethodRequest.Code))
                    _codeError = e.ErrorMessage;
                else if (e.PropertyName == nameof(CreatePaymentMethodRequest.Name))
                    _nameError = e.ErrorMessage;
                else if (e.PropertyName == nameof(CreatePaymentMethodRequest.Type))
                    _typeError = e.ErrorMessage;
                else
                    _error = e.ErrorMessage;
            }
        }
        finally
        {
            _saving = false;
        }
    }
}
