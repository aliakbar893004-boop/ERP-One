@page "/master/attributes/new"
@page "/master/attributes/{Id:int}/edit"
@attribute [Authorize]
@rendermode InteractiveServer
@using FluentValidation
@inject IAttributeService AttributeService
@inject IAuthorizationService Auth
@inject NavigationManager Nav

<PageTitle>@Title</PageTitle>

<div class="cf">

    <div class="cf-top">
        <div class="crumbs">
            <a href="/master/attributes">Master</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/master/attributes">Attributes</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(Id is null ? "New" : "Edit")</span>
        </div>
        <h1>@Title</h1>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_notFound)
    {
        <div class="cf-alert warn"><i class="bi bi-exclamation-triangle"></i> Attribute not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="cf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="cf-wrap">
            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-sliders2"></i></span>
                    <div class="hd-tx">
                        <h2>Attribute information</h2>
                        <p>A variant dimension such as Size or Colour.</p>
                    </div>
                </div>
                <div class="card-b">
                    <div class="grid">
                        <div class="f c4">
                            <label class="fl">Code <span class="req">*</span></label>
                            <input class="ctl mono up @(_codeError is not null ? "bad" : "")"
                                   placeholder="e.g. SIZE" maxlength="20"
                                   @bind="_code" @bind:event="oninput" />
                            @if (_codeError is not null)
                            {
                                <div class="err-txt">@_codeError</div>
                            }
                        </div>
                        <div class="f c8">
                            <label class="fl">Name <span class="req">*</span></label>
                            <input class="ctl @(_nameError is not null ? "bad" : "")"
                                   placeholder="e.g. Ukuran" maxlength="100"
                                   @bind="_name" @bind:event="oninput" />
                            @if (_nameError is not null)
                            {
                                <div class="err-txt">@_nameError</div>
                            }
                        </div>
                    </div>
                </div>
            </section>

            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-list-ul"></i></span>
                    <div class="hd-tx">
                        <h2>Values</h2>
                        <p>Options for this attribute, e.g. S, M, L.</p>
                    </div>
                    <button type="button" class="vadd" @onclick="AddValue"><i class="bi bi-plus-lg"></i> Add value</button>
                </div>
                <div class="card-b">
                    @if (_values.Count == 0)
                    {
                        <p class="vempty">No values yet. Click “Add value” to create options like S, M, L.</p>
                    }
                    else
                    {
                        <div class="vrow-head"><div>Code</div><div>Value</div><div></div></div>
                        @for (var i = 0; i < _values.Count; i++)
                        {
                            var idx = i;
                            <div class="vrow">
                                <input class="ctl sm mono up" placeholder="e.g. M" maxlength="20"
                                       @bind="_values[idx].Code" @bind:event="oninput" />
                                <input class="ctl sm" placeholder="e.g. Medium" maxlength="100"
                                       @bind="_values[idx].Value" @bind:event="oninput" />
                                <button type="button" class="vdel" @onclick="() => RemoveValue(idx)" title="Remove"><i class="bi bi-trash3"></i></button>
                            </div>
                        }
                    }
                </div>
            </section>

            <div class="pf-footer">
                <div class="in">
                    <span class="note"><span class="req">*</span> required fields</span>
                    <a class="btn btn-ghost" href="/master/attributes"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        else
                        {
                            <i class="bi bi-check2"></i>
                        }
                        Save attribute
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private sealed class ValueRow
    {
        public string Code { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private string _code = string.Empty;
    private string _name = string.Empty;
    private readonly List<ValueRow> _values = new();
    private bool _loading = true, _saving, _notFound;
    private string? _error, _codeError, _nameError;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string Title => Id is null ? "Add Attribute" : "Edit Attribute";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        var perm = Id is null
            ? AppMenus.Perm("master.attributes", "create")
            : AppMenus.Perm("master.attributes", "edit");

        if (!(await Auth.AuthorizeAsync(state.User, perm)).Succeeded)
        {
            Nav.NavigateTo("/master/attributes");
            return;
        }

        if (Id is int id)
        {
            var attr = await AttributeService.GetByIdAsync(id);
            if (attr is null)
                _notFound = true;
            else
            {
                _code = attr.Code;
                _name = attr.Name;
                foreach (var v in attr.Values)
                    _values.Add(new ValueRow { Code = v.Code, Value = v.Value });
            }
        }

        _loading = false;
    }

    private void AddValue() => _values.Add(new ValueRow());

    private void RemoveValue(int index)
    {
        if (index >= 0 && index < _values.Count)
            _values.RemoveAt(index);
    }

    private async Task SaveAsync()
    {
        _error = _codeError = _nameError = null;
        _saving = true;

        try
        {
            var values = _values
                .Select(v => new AttributeValueInput(v.Code, v.Value))
                .ToList();

            if (Id is int id)
                await AttributeService.UpdateAsync(id, new UpdateAttributeRequest(_code, _name, values));
            else
                await AttributeService.CreateAsync(new CreateAttributeRequest(_code, _name, values));

            Nav.NavigateTo("/master/attributes");
        }
        catch (ValidationException ex)
        {
            foreach (var e in ex.Errors)
            {
                if (e.PropertyName == nameof(CreateAttributeRequest.Code))
                    _codeError = e.ErrorMessage;
                else if (e.PropertyName == nameof(CreateAttributeRequest.Name))
                    _nameError = e.ErrorMessage;
                else
                    // nilai bermasalah (mis. "Values[0].Code") ditampilkan sebagai error umum
                    _error = string.IsNullOrEmpty(_error) ? e.ErrorMessage : $"{_error} {e.ErrorMessage}";
            }
        }
        finally
        {
            _saving = false;
        }
    }
}
