@page "/master/taxes/new"
@page "/master/taxes/{Id:int}/edit"
@attribute [Authorize]
@rendermode InteractiveServer
@using FluentValidation
@inject ITaxService TaxService
@inject IAuthorizationService Auth
@inject NavigationManager Nav

<PageTitle>@Title</PageTitle>

<div class="cf">

    <div class="cf-top">
        <div class="crumbs">
            <a href="/master/taxes">Master</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/master/taxes">Taxes</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(Id is null ? "New" : "Edit")</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_notFound)
    {
        <div class="cf-alert warn"><i class="bi bi-exclamation-triangle"></i> Tax not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="cf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="cf-wrap">
            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-percent"></i></span>
                    <div class="hd-tx">
                        <h2>Tax information</h2>
                        <p>A tax rate applied to transactions.</p>
                    </div>
                </div>
                <div class="card-b">
                    <div class="grid">
                        <div class="f c4">
                            <label class="fl">Code <span class="req">*</span></label>
                            <input class="ctl mono up @(_codeError is not null ? "bad" : "")"
                                   placeholder="e.g. PPN11" maxlength="20"
                                   @bind="_code" @bind:event="oninput" />
                            @if (_codeError is not null)
                            {
                                <div class="err-txt">@_codeError</div>
                            }
                        </div>
                        <div class="f c8">
                            <label class="fl">Name <span class="req">*</span></label>
                            <input class="ctl @(_nameError is not null ? "bad" : "")"
                                   placeholder="e.g. PPN 11%" maxlength="100"
                                   @bind="_name" @bind:event="oninput" />
                            @if (_nameError is not null)
                            {
                                <div class="err-txt">@_nameError</div>
                            }
                        </div>
                        <div class="f c4">
                            <label class="fl">Rate (%) <span class="req">*</span></label>
                            <input class="ctl mono @(_rateError is not null ? "bad" : "")"
                                   type="number" step="0.01" min="0" max="100"
                                   @bind="_rate" @bind:event="oninput" />
                            @if (_rateError is not null)
                            {
                                <div class="err-txt">@_rateError</div>
                            }
                        </div>
                        <div class="f c8">
                            <label class="fl">Tax mode</label>
                            <label class="tgl">
                                <input type="checkbox" @bind="_isInclusive" />
                                <span class="sw"></span>
                                <span class="tx">Tax inclusive<small>Tax is already included in the price</small></span>
                            </label>
                        </div>
                        <div class="f c12">
                            <label class="fl">Description</label>
                            <textarea class="ctl @(_descError is not null ? "bad" : "")"
                                      rows="3" maxlength="300" placeholder="Optional"
                                      @bind="_description" @bind:event="oninput"></textarea>
                            <div class="cnt">@(_description?.Length ?? 0)/300</div>
                            @if (_descError is not null)
                            {
                                <div class="err-txt">@_descError</div>
                            }
                        </div>
                    </div>
                </div>
            </section>

            <div class="pf-footer">
                <div class="in">
                    <span class="note"><span class="req">*</span> required fields</span>
                    <a class="btn btn-ghost" href="/master/taxes"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        else
                        {
                            <i class="bi bi-check2"></i>
                        }
                        Save tax
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private string _code = string.Empty;
    private string _name = string.Empty;
    private decimal _rate;
    private bool _isInclusive;
    private string? _description;
    private bool _loading = true, _saving, _notFound;
    private string? _error, _codeError, _nameError, _rateError, _descError;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string Title => Id is null ? "Add Tax" : "Edit Tax";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        var perm = Id is null
            ? AppMenus.Perm("master.taxes", "create")
            : AppMenus.Perm("master.taxes", "edit");

        if (!(await Auth.AuthorizeAsync(state.User, perm)).Succeeded)
        {
            Nav.NavigateTo("/master/taxes");
            return;
        }

        if (Id is int id)
        {
            var tax = await TaxService.GetByIdAsync(id);
            if (tax is null)
                _notFound = true;
            else
            {
                _code = tax.Code;
                _name = tax.Name;
                _rate = tax.Rate;
                _isInclusive = tax.IsInclusive;
                _description = tax.Description;
            }
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        _error = _codeError = _nameError = _rateError = _descError = null;
        _saving = true;

        try
        {
            if (Id is int id)
                await TaxService.UpdateAsync(id, new UpdateTaxRequest(_code, _name, _rate, _isInclusive, _description));
            else
                await TaxService.CreateAsync(new CreateTaxRequest(_code, _name, _rate, _isInclusive, _description));

            Nav.NavigateTo("/master/taxes");
        }
        catch (ValidationException ex)
        {
            foreach (var e in ex.Errors)
            {
                if (e.PropertyName == nameof(CreateTaxRequest.Code))
                    _codeError = e.ErrorMessage;
                else if (e.PropertyName == nameof(CreateTaxRequest.Name))
                    _nameError = e.ErrorMessage;
                else if (e.PropertyName == nameof(CreateTaxRequest.Rate))
                    _rateError = e.ErrorMessage;
                else if (e.PropertyName == nameof(CreateTaxRequest.Description))
                    _descError = e.ErrorMessage;
                else
                    _error = e.ErrorMessage;
            }
        }
        finally
        {
            _saving = false;
        }
    }
}
