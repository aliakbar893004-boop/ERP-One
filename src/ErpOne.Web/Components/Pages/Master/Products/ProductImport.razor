@page "/master/products/import"
@attribute [Authorize(Policy = "master.products.create")]
@rendermode InteractiveServer
@using ClosedXML.Excel
@using System.Globalization
@inject IProductService ProductService
@inject SwalService Swal

<PageTitle>Upload Product Data</PageTitle>

<div class="uf-header mb-4">
    <a class="back-link" href="/master/products"><i class="bi bi-arrow-left me-1"></i>Back</a>
    <h4 class="uf-title">Upload Product Data</h4>
</div>

<div class="row g-4">
    <div class="col-12 col-xl-8">

        <div class="fs-card mb-4">
            <div class="fs-card-head head-images">
                <i class="bi bi-file-earmark-excel"></i> Import from Excel
            </div>
            <div class="fs-card-body">
                <ol class="text-muted small mb-3 ps-3">
                    <li>Download the Excel template and fill it in (one product per row).</li>
                    <li><strong>CategoryCode</strong> must match an existing category code (e.g. <code>KAT-01</code>).</li>
                    <li>SKU is generated automatically — do not include it.</li>
                    <li>Status: Aktif / Nonaktif / Habis / Arsip. Keep the header row.</li>
                </ol>

                <a class="btn btn-outline-secondary btn-sm mb-3" href="/master/products/import-template">
                    <i class="bi bi-download me-1"></i>Download template (.xlsx)
                </a>

                <div>
                    <label class="img-upload">
                        <InputFile OnChange="OnFileSelectedAsync" accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" />
                        <i class="bi bi-file-earmark-excel me-1"></i>
                        @(_fileName is null ? "Choose Excel file (.xlsx)" : _fileName)
                    </label>
                </div>

                @if (_parseError is not null)
                {
                    <div class="alert alert-danger py-2 small mt-3 mb-0">
                        <i class="bi bi-exclamation-triangle me-1"></i>@_parseError
                    </div>
                }

                @if (_rows is not null)
                {
                    <div class="alert alert-info py-2 small mt-3 mb-0 d-flex align-items-center justify-content-between">
                        <span><i class="bi bi-list-check me-1"></i><strong>@_rows.Count</strong> row(s) ready to import.</span>
                        <button class="btn btn-primary btn-sm" @onclick="ImportAsync" disabled="@_importing">
                            @if (_importing)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            else
                            {
                                <i class="bi bi-cloud-arrow-up me-1"></i>
                            }
                            Import @_rows.Count product(s)
                        </button>
                    </div>
                }
            </div>
        </div>

        @if (_result is not null)
        {
            <div class="fs-card mb-4">
                <div class="fs-card-head head-price">
                    <i class="bi bi-clipboard-check"></i> Import Result
                </div>
                <div class="fs-card-body">
                    <div class="d-flex gap-3 mb-3">
                        <span class="badge bg-success-subtle text-success-emphasis fs-6">
                            <i class="bi bi-check-circle me-1"></i>@_result.SuccessCount imported
                        </span>
                        @if (_result.FailedCount > 0)
                        {
                            <span class="badge bg-danger-subtle text-danger-emphasis fs-6">
                                <i class="bi bi-x-circle me-1"></i>@_result.FailedCount failed
                            </span>
                        }
                    </div>

                    @if (_result.Errors.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr><th style="width:90px">Row</th><th>Error</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var err in _result.Errors)
                                    {
                                        <tr>
                                            <td class="text-muted">@err.RowNumber</td>
                                            <td class="small">@err.Message</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <div class="mt-3">
                        <a class="btn btn-outline-primary btn-sm" href="/master/products">
                            <i class="bi bi-box-seam me-1"></i>Go to products
                        </a>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

@code {
    private const long MaxFileSize = 5 * 1024 * 1024;

    private string? _fileName;
    private string? _parseError;
    private List<ProductImportRow>? _rows;
    private ProductImportResult? _result;
    private bool _importing;

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        _parseError = null;
        _rows = null;
        _result = null;
        _fileName = e.File.Name;

        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(MaxFileSize).CopyToAsync(ms);
            ms.Position = 0;
            _rows = ParseExcel(ms);

            if (_rows.Count == 0)
                _parseError = "No data rows found in the file.";
        }
        catch (Exception ex)
        {
            _rows = null;
            _parseError = $"Could not read the file: {ex.Message}";
        }
    }

    private async Task ImportAsync()
    {
        if (_rows is null || _rows.Count == 0) return;

        _importing = true;
        try
        {
            _result = await ProductService.ImportAsync(_rows);
            _rows = null;

            if (_result.FailedCount == 0)
                await Swal.ToastAsync("success", $"{_result.SuccessCount} product(s) imported");
            else
                await Swal.ToastAsync("warning", $"{_result.SuccessCount} imported, {_result.FailedCount} failed");
        }
        catch (Exception)
        {
            await Swal.ToastAsync("error", "Import failed");
        }
        finally
        {
            _importing = false;
        }
    }

    private static List<ProductImportRow> ParseExcel(Stream stream)
    {
        var rows = new List<ProductImportRow>();

        using var wb = new XLWorkbook(stream);
        var ws = wb.Worksheets.FirstOrDefault();
        if (ws is null) return rows;

        var range = ws.RangeUsed();
        if (range is null) return rows;

        var firstRow = range.FirstRow().RowNumber();
        var lastRow = range.LastRow().RowNumber();
        var firstCol = range.FirstColumn().ColumnNumber();
        var lastCol = range.LastColumn().ColumnNumber();

        // Petakan nama kolom (header di baris pertama range) → nomor kolom.
        var map = new Dictionary<string, int>();
        for (var c = firstCol; c <= lastCol; c++)
        {
            var key = Normalize(ws.Cell(firstRow, c).GetString());
            if (key.Length > 0 && !map.ContainsKey(key))
                map[key] = c;
        }

        string? Get(int row, string key) =>
            map.TryGetValue(key, out var col) ? CellText(ws.Cell(row, col)) : null;

        for (var r = firstRow + 1; r <= lastRow; r++)
        {
            // Lewati baris kosong sepenuhnya.
            if (ws.Row(r).CellsUsed().All(c => string.IsNullOrWhiteSpace(c.GetString())))
                continue;

            rows.Add(new ProductImportRow(
                RowNumber: r,
                CategoryCode: Get(r, "categorycode"),
                Name: Get(r, "name"),
                Description: Get(r, "description"),
                Price: Get(r, "price"),
                DiscountPrice: Get(r, "discountprice"),
                Stock: Get(r, "stock"),
                Weight: Get(r, "weight"),
                Dimensions: Get(r, "dimensions"),
                Status: Get(r, "status")));
        }

        return rows;
    }

    private static string? CellText(IXLCell cell)
    {
        if (cell.IsEmpty()) return null;
        var text = cell.DataType == XLDataType.Number
            ? cell.GetValue<double>().ToString(CultureInfo.InvariantCulture)
            : cell.GetString().Trim();
        return string.IsNullOrWhiteSpace(text) ? null : text;
    }

    private static string Normalize(string header) =>
        new string(header.Where(c => !char.IsWhiteSpace(c) && c != '_').ToArray()).ToLowerInvariant();
}
