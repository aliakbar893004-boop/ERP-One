@page "/master/warehouses"
@attribute [Authorize(Policy = "master.warehouses.index")]
@rendermode InteractiveServer
@inject IWarehouseService WarehouseService
@inject NavigationManager Nav
@inject SwalService Swal

<PageTitle>Warehouses</PageTitle>

<div class="pi">

    <div class="pi-head">
        <div>
            <nav class="crumbs">
                <a href="/">Home</a>
                <span class="sep">·</span>
                <span>Master</span>
                <span class="sep">·</span>
                <h1>Warehouses</h1>
            </nav>
            <p>Manage warehouses and locations.</p>
        </div>
        <AuthorizeView Policy="master.warehouses.create">
            <Authorized>
                <div class="pi-actions">
                    <a class="btn btn-primary" href="/master/warehouses/new"><i class="bi bi-plus-lg"></i> Add warehouse</a>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_summary is not null)
    {
        <div class="kpis k3">
            <div class="kpi">
                <div class="ic ic-blu"><i class="bi bi-buildings"></i></div>
                <div class="kpi-tx">
                    <div class="v">@_summary.Total.ToString("N0")</div>
                    <div class="l">Total warehouses</div>
                </div>
            </div>
            <div class="kpi">
                <div class="ic ic-grn"><i class="bi bi-check-circle"></i></div>
                <div class="kpi-tx">
                    <div class="v">@_summary.Active.ToString("N0")</div>
                    <div class="l">Active</div>
                </div>
            </div>
            <div class="kpi">
                <div class="ic ic-red"><i class="bi bi-slash-circle"></i></div>
                <div class="kpi-tx">
                    <div class="v">@_summary.Inactive.ToString("N0")</div>
                    <div class="l">Inactive</div>
                </div>
            </div>
        </div>
    }

    <div class="toolbar">
        <div class="search">
            <i class="bi bi-search"></i>
            <input placeholder="Search code or name…" @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
        <div class="chips">
            <button class="chip @(_active is null ? "on" : "")" @onclick="() => SetActiveAsync(null)">All</button>
            <button class="chip @(_active == true ? "on" : "")" @onclick="() => SetActiveAsync(true)">Active</button>
            <button class="chip @(_active == false ? "on" : "")" @onclick="() => SetActiveAsync(false)">Inactive</button>
        </div>
    </div>

    @if (_page is null)
    {
        <div class="pi-loading"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading…</div>
    }
    else if (_page.Total == 0)
    {
        <div class="empty">
            <div class="empty-ic"><i class="bi bi-buildings"></i></div>
            <p>
                @if (string.IsNullOrEmpty(_search) && _active is null)
                {
                    <span>No warehouses yet. <a href="/master/warehouses/new">Add the first one.</a></span>
                }
                else
                {
                    <span>No warehouses match your filters.</span>
                }
            </p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-top">
                <span class="n">Showing <b>@((_page.Page - 1) * PageSize + 1)–@Math.Min(_page.Page * PageSize, _page.Total)</b> of <b>@_page.Total.ToString("N0")</b></span>
            </div>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th style="width:140px">Code</th>
                            <th>Name</th>
                            <th>Address</th>
                            <th class="c" style="width:100px">Default</th>
                            <th class="c" style="width:110px">Status</th>
                            <th>Created</th>
                            <th class="text-end pe-3" style="width:120px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _page.Items)
                        {
                            <tr>
                                <td class="code mono">@item.Code</td>
                                <td class="nm">@item.Name</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Address) ? "—" : item.Address)</td>
                                <td class="c">
                                    @if (item.IsDefault)
                                    {
                                        <span class="badge b-info">Default</span>
                                    }
                                    else
                                    {
                                        <span class="code">—</span>
                                    }
                                </td>
                                <td class="c">
                                    <span class="badge @(item.IsActive ? "b-ok" : "b-off")">@(item.IsActive ? "Active" : "Inactive")</span>
                                </td>
                                <td class="code text-nowrap">
                                    @item.CreatedAt.ToLocalTime().ToString("d MMM yyyy")
                                    @if (item.CreatedBy is not null)
                                    {
                                        <span class="opacity-75">· @item.CreatedBy</span>
                                    }
                                </td>
                                <td class="text-end pe-3 text-nowrap">
                                    <AuthorizeView Policy="master.warehouses.edit">
                                        <Authorized>
                                            <a class="btn btn-sm btn-outline-primary me-1" href="@($"/master/warehouses/{item.Id}/edit")" title="Edit"><i class="bi bi-pencil"></i></a>
                                        </Authorized>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="master.warehouses.delete">
                                        <Authorized>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.Id, item.Name)" title="Delete"><i class="bi bi-trash3"></i></button>
                                        </Authorized>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_page.TotalPages > 1)
            {
                <div class="card-foot">
                    <Pager Page="_page.Page" TotalPages="_page.TotalPages" OnPageChanged="GoToPageAsync" />
                </div>
            }
        </div>
    }
</div>

@code {
    private const int PageSize = 15;
    private PagedResult<WarehouseDto>? _page;
    private MasterListSummary? _summary;
    private int _currentPage = 1;
    private string? _search;
    private bool? _active;

    protected override async Task OnInitializedAsync()
    {
        _summary = await WarehouseService.GetSummaryAsync();
        await LoadAsync();
    }

    private async Task LoadAsync() =>
        _page = await WarehouseService.GetPagedAsync(_currentPage, PageSize, _search, _active);

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task SetActiveAsync(bool? active)
    {
        _active = active;
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        _currentPage = page;
        await LoadAsync();
    }

    private async Task DeleteAsync(int id, string name)
    {
        if (!await Swal.ConfirmAsync("Delete warehouse?", $"\"{name}\" will be permanently removed."))
            return;

        await WarehouseService.DeleteAsync(id);
        _summary = await WarehouseService.GetSummaryAsync();
        await LoadAsync();
        await Swal.ToastAsync("success", "Warehouse deleted");
    }
}
