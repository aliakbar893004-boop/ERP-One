@page "/settings/users/new"
@page "/settings/users/{Id}/edit"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<ApplicationRole> RoleManager
@inject IAuthorizationService Auth
@inject NavigationManager Nav

<PageTitle>@_title</PageTitle>

<div class="cf">

    <div class="cf-top">
        <div class="crumbs">
            <a href="/settings/users">Settings</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/settings/users">Users</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(IsNew ? "New" : "Edit")</span>
        </div>
        <h1>@_title</h1>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_notFound)
    {
        <div class="cf-alert warn"><i class="bi bi-exclamation-triangle"></i> User not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="cf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="cf-wrap">

            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-person-badge"></i></span>
                    <div class="hd-tx">
                        <h2>Account information</h2>
                        <p>Identity and contact details for this user.</p>
                    </div>
                </div>
                <div class="card-b">
                    <div class="grid">
                        <div class="f c6">
                            <label class="fl">Display Name <span class="req">*</span></label>
                            <input class="ctl" placeholder="Full name" @bind="_displayName" @bind:event="oninput" />
                        </div>
                        <div class="f c6">
                            <label class="fl">Username @if (IsNew) { <span class="req">*</span> }</label>
                            <div class="ig">
                                <span class="ig-pre">@@</span>
                                <input class="ctl mono has-pre" placeholder="username" @bind="_userName" @bind:event="oninput" disabled="@(!IsNew)" />
                            </div>
                        </div>
                        <div class="f c6">
                            <label class="fl">Email</label>
                            <input class="ctl" type="email" placeholder="email@domain.com" @bind="_email" />
                        </div>
                        <div class="f c6">
                            <label class="fl">Phone Number</label>
                            <input class="ctl" type="tel" placeholder="+62 8xx-xxxx-xxxx" @bind="_phone" />
                        </div>
                        <div class="f c12">
                            <label class="tgl">
                                <input type="checkbox" @bind="_isActive" />
                                <span class="sw"></span>
                                <span class="tx">Account active<small>@(_isActive ? "User can sign in" : "User cannot sign in")</small></span>
                            </label>
                        </div>
                    </div>
                </div>
            </section>

            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-shield-lock"></i></span>
                    <div class="hd-tx">
                        <h2>Security</h2>
                        <p>@(IsNew ? "Set an initial password for the account." : "Leave blank to keep the current password.")</p>
                    </div>
                </div>
                <div class="card-b">
                    <div class="grid">
                        <div class="f c6">
                            <label class="fl">@(IsNew ? "Password" : "New Password") @if (IsNew) { <span class="req">*</span> }</label>
                            <div class="pwd">
                                <input class="ctl" type="@(_showPwd ? "text" : "password")" @bind="_password"
                                       placeholder="@(IsNew ? "At least 6 characters" : "Fill to change")" />
                                <button type="button" class="pwd-eye" @onclick="() => _showPwd = !_showPwd"
                                        title="@(_showPwd ? "Hide password" : "Show password")">
                                    <i class="bi @(_showPwd ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            @if (_allRoles.Count > 0)
            {
                <section class="card">
                    <div class="card-h">
                        <span class="hd-ic"><i class="bi bi-key"></i></span>
                        <div class="hd-tx">
                            <h2>Access rights</h2>
                            <p>Select one or more roles for this user.</p>
                        </div>
                    </div>
                    <div class="card-b">
                        <div class="grid">
                            @foreach (var r in _allRoles)
                            {
                                <div class="f c6">
                                    <label class="tgl">
                                        <input type="checkbox" checked="@_selectedRoles.Contains(r)"
                                               @onchange="e => ToggleRole(r, (bool)(e.Value ?? false))" />
                                        <span class="sw"></span>
                                        <span class="tx">@r</span>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            }

            <div class="pf-footer">
                <div class="in">
                    <span class="note"><span class="req">*</span> required fields</span>
                    <a class="btn btn-ghost" href="/settings/users"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        else
                        {
                            <i class="bi bi-check2"></i>
                        }
                        Save user
                    </button>
                </div>
            </div>

        </div>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }

    private string _userName    = string.Empty;
    private string _displayName = string.Empty;
    private string? _email;
    private string? _phone;
    private string? _password;
    private bool _isActive = true;
    private bool _showPwd;
    private List<string> _allRoles = [];
    private readonly HashSet<string> _selectedRoles = [];

    private bool _loading = true, _saving, _notFound;
    private string? _error;
    private ApplicationUser? _user;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool IsNew => Id is null;
    private string _title => IsNew ? "Add User" : "Edit User";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        var perm  = IsNew ? AppMenus.Perm("settings.users", "create")
                          : AppMenus.Perm("settings.users", "edit");
        if (!(await Auth.AuthorizeAsync(state.User, perm)).Succeeded)
        {
            Nav.NavigateTo("/settings/users");
            return;
        }

        _allRoles = await RoleManager.Roles.OrderBy(r => r.Name).Select(r => r.Name!).ToListAsync();

        if (Id is not null)
        {
            _user = await UserManager.FindByIdAsync(Id);
            if (_user is null)
            {
                _notFound = true;
            }
            else
            {
                _userName    = _user.UserName ?? "";
                _displayName = _user.DisplayName;
                _email       = _user.Email;
                _phone       = _user.PhoneNumber;
                _isActive    = _user.IsActive;
                foreach (var r in await UserManager.GetRolesAsync(_user))
                    _selectedRoles.Add(r);
            }
        }
        _loading = false;
    }

    private void ToggleRole(string role, bool selected)
    {
        if (selected) _selectedRoles.Add(role);
        else _selectedRoles.Remove(role);
    }

    private async Task SaveAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_displayName)) { _error = "Display name is required."; return; }
        if (IsNew && string.IsNullOrWhiteSpace(_userName))   { _error = "Username is required."; return; }
        if (IsNew && string.IsNullOrWhiteSpace(_password))   { _error = "Password is required for new users."; return; }

        _saving = true;
        try
        {
            if (IsNew)
            {
                var user = new ApplicationUser
                {
                    UserName      = _userName.Trim(),
                    Email         = Nullify(_email),
                    EmailConfirmed = true,
                    PhoneNumber   = Nullify(_phone),
                    DisplayName   = _displayName.Trim(),
                    IsActive      = _isActive
                };
                var created = await UserManager.CreateAsync(user, _password!);
                if (!created.Succeeded) { _error = Errors(created); return; }
                if (_selectedRoles.Count > 0)
                    await UserManager.AddToRolesAsync(user, _selectedRoles);
            }
            else
            {
                _user!.DisplayName  = _displayName.Trim();
                _user.Email         = Nullify(_email);
                _user.PhoneNumber   = Nullify(_phone);
                _user.IsActive      = _isActive;
                var updated = await UserManager.UpdateAsync(_user);
                if (!updated.Succeeded) { _error = Errors(updated); return; }

                var current  = await UserManager.GetRolesAsync(_user);
                var toRemove = current.Except(_selectedRoles).ToList();
                var toAdd    = _selectedRoles.Except(current).ToList();
                if (toRemove.Count > 0) await UserManager.RemoveFromRolesAsync(_user, toRemove);
                if (toAdd.Count > 0)    await UserManager.AddToRolesAsync(_user, toAdd);

                if (!string.IsNullOrWhiteSpace(_password))
                {
                    var token = await UserManager.GeneratePasswordResetTokenAsync(_user);
                    var reset = await UserManager.ResetPasswordAsync(_user, token, _password);
                    if (!reset.Succeeded) { _error = Errors(reset); return; }
                }
            }

            Nav.NavigateTo("/settings/users");
        }
        finally { _saving = false; }
    }

    private static string? Nullify(string? v) =>
        string.IsNullOrWhiteSpace(v) ? null : v.Trim();

    private static string Errors(IdentityResult r) =>
        string.Join(" ", r.Errors.Select(e => e.Description));
}
