@page "/settings/error-log"
@attribute [Authorize(Policy = "settings.errorlog.index")]
@rendermode InteractiveServer
@inject ILogService LogService

<PageTitle>Error Log</PageTitle>

<div class="pi">

    <div class="pi-head">
        <div>
            <nav class="crumbs"><a href="/">Home</a><span class="sep">·</span><span>Settings</span><span class="sep">·</span><span class="here">Error Log</span></nav>
            <h1>Error Log</h1>
            <p>Review recent system warnings and errors.</p>
        </div>
        <div class="pi-actions">
            <button class="btn btn-primary" @onclick="LoadAsync"><i class="bi bi-arrow-clockwise"></i> Reload</button>
        </div>
    </div>

    <div class="toolbar">
        <div class="chips">
            <button class="chip @(_level == "" ? "on" : "")" @onclick='() => SetLevelAsync("")'>All</button>
            <button class="chip @(_level == "Warning" ? "on" : "")" @onclick='() => SetLevelAsync("Warning")'>Warning</button>
            <button class="chip @(_level == "Error" ? "on" : "")" @onclick='() => SetLevelAsync("Error")'>Error</button>
            <button class="chip @(_level == "Fatal" ? "on" : "")" @onclick='() => SetLevelAsync("Fatal")'>Fatal</button>
        </div>
    </div>

    @if (_logs is null)
    {
        <div class="pi-loading"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading…</div>
    }
    else if (_logs.Count == 0)
    {
        <div class="empty">
            <div class="empty-ic"><i class="bi bi-clipboard-check"></i></div>
            <p>No log entries@(string.IsNullOrEmpty(_level) ? "" : $" at level {_level}") .</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-top">
                <span class="n">Latest <b>@_logs.Count</b> entr@(_logs.Count == 1 ? "y" : "ies")</span>
            </div>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th style="width:170px">Time</th>
                            <th style="width:110px">Level</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in _logs)
                        {
                            <tr>
                                <td class="code text-nowrap">@log.TimeStamp.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</td>
                                <td><span class="lvl @LvlClass(log.Level)">@log.Level</span></td>
                                <td>
                                    <div class="msg">@log.Message</div>
                                    @if (!string.IsNullOrWhiteSpace(log.Exception))
                                    {
                                        <details class="exc">
                                            <summary><i class="bi bi-bug"></i> Exception detail</summary>
                                            <pre>@log.Exception</pre>
                                        </details>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private IReadOnlyList<LogEntryDto>? _logs;
    private string _level = "";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() =>
        _logs = await LogService.GetRecentAsync(200, string.IsNullOrEmpty(_level) ? null : _level);

    private async Task SetLevelAsync(string level)
    {
        _level = level;
        await LoadAsync();
    }

    private static string LvlClass(string level) => level switch
    {
        "Error" => "lvl-err",
        "Fatal" => "lvl-fatal",
        "Warning" => "lvl-warn",
        _ => "lvl-info"
    };
}
