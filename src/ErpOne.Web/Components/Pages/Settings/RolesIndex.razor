@page "/settings/roles"
@attribute [Authorize(Policy = "settings.roles.index")]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@inject RoleManager<ApplicationRole> RoleManager
@inject SwalService Swal

<PageTitle>Role Management</PageTitle>

<div class="pi">

    <div class="pi-head">
        <div>
            <nav class="crumbs"><a href="/">Home</a><span class="sep">·</span><span>Settings</span><span class="sep">·</span><span class="here">Roles</span></nav>
            <h1>Role Management</h1>
            <p>Manage user access groups and their permissions.</p>
        </div>
        <AuthorizeView Policy="settings.roles.create">
            <Authorized>
                <div class="pi-actions">
                    <a class="btn btn-primary" href="/settings/roles/new"><i class="bi bi-shield-plus"></i> Add role</a>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_roles is null)
    {
        <div class="pi-loading"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading…</div>
    }
    else if (_roles.Count == 0)
    {
        <div class="empty">
            <div class="empty-ic"><i class="bi bi-shield-lock"></i></div>
            <p>No roles yet. <a href="/settings/roles/new">Add the first one.</a></p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-top">
                <span class="n"><b>@_roles.Count</b> role@(_roles.Count == 1 ? "" : "s")</span>
            </div>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th style="width:220px">Role</th>
                            <th>Description</th>
                            <th class="text-end pe-3" style="width:120px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _roles)
                        {
                            <tr>
                                <td><span class="role-chip"><i class="bi bi-shield-fill"></i> @r.Name</span></td>
                                <td>@(string.IsNullOrWhiteSpace(r.Description) ? "—" : r.Description)</td>
                                <td class="text-end pe-3 text-nowrap">
                                    <AuthorizeView Policy="settings.roles.edit">
                                        <Authorized>
                                            <a class="btn btn-sm btn-outline-primary me-1" href="@($"/settings/roles/{r.Id}/edit")" title="Edit"><i class="bi bi-pencil"></i></a>
                                        </Authorized>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="settings.roles.delete">
                                        <Authorized>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(r.Id, r.Name)" title="Delete"><i class="bi bi-trash3"></i></button>
                                        </Authorized>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<ApplicationRole>? _roles;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() =>
        _roles = await RoleManager.Roles.OrderBy(r => r.Name).ToListAsync();

    private async Task DeleteAsync(string id, string? name)
    {
        if (!await Swal.ConfirmAsync("Delete role?", $"\"{name}\" will be permanently removed."))
            return;

        var role = await RoleManager.FindByIdAsync(id);
        if (role is not null) await RoleManager.DeleteAsync(role);
        await LoadAsync();
        await Swal.ToastAsync("success", "Role deleted");
    }
}
