@page "/settings/roles"
@attribute [Authorize(Policy = "settings.roles.index")]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@inject RoleManager<ApplicationRole> RoleManager

<PageTitle>Role Management</PageTitle>

<div class="sh-header mb-4">
    <div>
        <h4 class="sh-title">Role Management</h4>
        <p class="sh-subtitle">Manage user access groups</p>
    </div>
    <AuthorizeView Policy="settings.roles.create">
        <Authorized>
            <a class="btn btn-primary btn-sm" href="/settings/roles/new">
                <i class="bi bi-shield-plus me-1"></i> Add Role
            </a>
        </Authorized>
    </AuthorizeView>
</div>

@if (_roles is null)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        Loading data...
    </div>
}
else if (_roles.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">&#128737;</div>
        <p class="empty-text">No roles yet.</p>
    </div>
}
else
{
    <div class="data-card">
        <div class="data-card-header">
            <span class="text-muted small">@_roles.Count roles</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-head">
                    <tr>
                        <th>Role Name</th>
                        <th>Description</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _roles)
                    {
                        <tr>
                            <td>
                                <span class="role-chip">@r.Name</span>
                            </td>
                            <td class="text-muted small">@(r.Description ?? "–")</td>
                            <td class="text-end text-nowrap">
                                @if (_confirmDeleteId == r.Id)
                                {
                                    <span class="text-danger small fw-semibold me-2">Delete?</span>
                                    <button class="btn btn-sm btn-danger me-1"
                                            @onclick="() => ConfirmDeleteAsync(r.Id)">
                                        <i class="bi bi-check2 me-1"></i>Yes
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            @onclick="CancelDelete">
                                        <i class="bi bi-x-lg me-1"></i>Cancel
                                    </button>
                                }
                                else
                                {
                                    <AuthorizeView Policy="settings.roles.edit">
                                        <Authorized>
                                            <a class="btn btn-sm btn-outline-primary me-1"
                                               href="@($"/settings/roles/{r.Id}/edit")">
                                                <i class="bi bi-pencil-fill me-1"></i>Edit
                                            </a>
                                        </Authorized>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="settings.roles.delete">
                                        <Authorized>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => _confirmDeleteId = r.Id">
                                                <i class="bi bi-trash3-fill me-1"></i>Delete
                                            </button>
                                        </Authorized>
                                    </AuthorizeView>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<ApplicationRole>? _roles;
    private string? _confirmDeleteId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() =>
        _roles = await RoleManager.Roles.OrderBy(r => r.Name).ToListAsync();

    private void CancelDelete() => _confirmDeleteId = null;

    private async Task ConfirmDeleteAsync(string id)
    {
        _confirmDeleteId = null;
        var role = await RoleManager.FindByIdAsync(id);
        if (role is not null) await RoleManager.DeleteAsync(role);
        await LoadAsync();
    }
}
