@page "/settings/approval-chains"
@attribute [Authorize(Policy = "settings.approval-chains.index")]
@rendermode InteractiveServer
@using ErpOne.Application.Approvals
@using ErpOne.Domain.Entities
@inject IApprovalChainService ChainService

<PageTitle>Approval Chains</PageTitle>

<div class="pi">

    <div class="pi-head">
        <div>
            <nav class="crumbs"><a href="/">Home</a><span class="sep">·</span><span>Settings</span><span class="sep">·</span><span class="here">Approval Chains</span></nav>
            <h1>Approval Chains</h1>
            <p>Configure the role approval sequence for each document type. An empty chain means a document is approved immediately on submit.</p>
        </div>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th style="width:240px">Document</th>
                        <th>Chain (role order)</th>
                        <th class="text-end pe-3" style="width:90px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dt in Enum.GetValues<ApprovalDocumentType>())
                    {
                        var chain = _chains.GetValueOrDefault(dt, []);
                        <tr>
                            <td class="nm">@dt</td>
                            <td>
                                @if (chain.Count == 0)
                                {
                                    <span class="muted-txt">— empty (auto-approve) —</span>
                                }
                                else
                                {
                                    <span class="chain">
                                        @for (var i = 0; i < chain.Count; i++)
                                        {
                                            <span class="step">@chain[i].RoleName</span>
                                            @if (i < chain.Count - 1)
                                            {
                                                <i class="bi bi-arrow-right sep"></i>
                                            }
                                        }
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <AuthorizeView Policy="settings.approval-chains.edit">
                                    <Authorized>
                                        <a class="btn btn-sm btn-outline-primary" href="@($"/settings/approval-chains/{dt}")" title="Edit"><i class="bi bi-pencil"></i></a>
                                    </Authorized>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private readonly Dictionary<ApprovalDocumentType, IReadOnlyList<ApprovalChainStepDto>> _chains = [];

    protected override async Task OnInitializedAsync()
    {
        foreach (var dt in Enum.GetValues<ApprovalDocumentType>())
            _chains[dt] = await ChainService.GetByDocumentTypeAsync(dt);
    }
}
