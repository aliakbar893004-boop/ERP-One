@page "/settings/approval-chains/{DocType}"
@attribute [Authorize(Policy = "settings.approval-chains.edit")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using ErpOne.Application.Approvals
@using ErpOne.Domain.Entities
@using ErpOne.Infrastructure.Identity
@inject IApprovalChainService ChainService
@inject RoleManager<ApplicationRole> RoleManager
@inject NavigationManager Nav

<PageTitle>Approval Chain — @DocType</PageTitle>

<div class="cf">

    <div class="cf-top">
        <div class="crumbs">
            <a href="/settings/approval-chains">Settings</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/settings/approval-chains">Approval Chains</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@DocType</span>
        </div>
        <h1>Approval Chain — @DocType</h1>
    </div>

    @if (!_valid)
    {
        <div class="cf-alert warn"><i class="bi bi-exclamation-triangle"></i> Unknown document type.</div>
    }
    else
    {
        @if (_saved)
        {
            <div class="cf-alert ok"><i class="bi bi-check-circle"></i> Saved.</div>
        }

        <div class="cf-wrap">
            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-diagram-3"></i></span>
                    <div class="hd-tx">
                        <h2>Steps (top to bottom)</h2>
                        <p>Each role approves in order and can be used only once — the same person can't approve twice. An empty chain auto-approves on submit.</p>
                    </div>
                    <button type="button" class="vadd" @onclick="AddStep" disabled="@(_steps.Count >= _roles.Count)"><i class="bi bi-plus-lg"></i> Add step</button>
                </div>
                <div class="card-b">
                    @if (_steps.Count == 0)
                    {
                        <p class="vempty">No steps yet — the document will be approved immediately on submit.</p>
                    }
                    else
                    {
                        @for (var i = 0; i < _steps.Count; i++)
                        {
                            var idx = i;
                            <div class="ac-step">
                                <span class="ac-num">@(idx + 1)</span>
                                <select class="ctl" @bind="_steps[idx]">
                                    <option value="">— select role —</option>
                                    @foreach (var r in _roles.Where(r => !UsedByOther(idx, r)))
                                    {
                                        <option value="@r">@r</option>
                                    }
                                </select>
                                <button type="button" class="ac-btn" @onclick="() => MoveUp(idx)" disabled="@(idx == 0)" title="Move up"><i class="bi bi-arrow-up"></i></button>
                                <button type="button" class="ac-btn del" @onclick="() => _steps.RemoveAt(idx)" title="Remove"><i class="bi bi-x-lg"></i></button>
                            </div>
                        }
                    }
                </div>
            </section>

            <div class="pf-footer">
                <div class="in">
                    <span class="note">@_steps.Count(s => !string.IsNullOrWhiteSpace(s)) role(s) in this chain</span>
                    <a class="btn btn-ghost" href="/settings/approval-chains"><i class="bi bi-x-lg"></i> Back</a>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        else
                        {
                            <i class="bi bi-check2"></i>
                        }
                        Save chain
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string DocType { get; set; } = "";

    private ApprovalDocumentType _dt;
    private bool _valid, _saving, _saved;
    private List<string> _roles = [];
    private readonly List<string> _steps = [];

    protected override async Task OnInitializedAsync()
    {
        _valid = Enum.TryParse(DocType, out _dt);
        if (!_valid) return;

        _roles = RoleManager.Roles.Select(r => r.Name!).OrderBy(n => n).ToList();
        var chain = await ChainService.GetByDocumentTypeAsync(_dt);
        foreach (var c in chain) _steps.Add(c.RoleName);
    }

    private void AddStep() { _steps.Add(""); _saved = false; }

    private void MoveUp(int idx)
    {
        if (idx <= 0) return;
        (_steps[idx - 1], _steps[idx]) = (_steps[idx], _steps[idx - 1]);
    }

    // A role already chosen in another step is hidden from this step's dropdown,
    // so a role (and its holder) can never appear twice in the chain.
    private bool UsedByOther(int idx, string role) =>
        _steps.Where((s, i) => i != idx)
              .Any(s => string.Equals(s, role, StringComparison.OrdinalIgnoreCase));

    private async Task SaveAsync()
    {
        _saving = true; _saved = false;
        var inputs = _steps.Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Select((role, i) => new ApprovalChainStepInput(i + 1, role)).ToList();
        await ChainService.ReplaceChainAsync(_dt, inputs);
        _saved = true; _saving = false;
    }
}
