@page "/settings/users"
@attribute [Authorize(Policy = "settings.users.index")]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject SwalService Swal

<PageTitle>User Management</PageTitle>

<div class="pi">

    <div class="pi-head">
        <div>
            <nav class="crumbs"><a href="/">Home</a><span class="sep">·</span><span>Settings</span><span class="sep">·</span><span class="here">Users</span></nav>
            <h1>User Management</h1>
            <p>Manage user accounts and system access.</p>
        </div>
        <AuthorizeView Policy="settings.users.create">
            <Authorized>
                <div class="pi-actions">
                    <a class="btn btn-primary" href="/settings/users/new"><i class="bi bi-person-plus"></i> Add user</a>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_rows is not null)
    {
        <div class="kpis k3">
            <div class="kpi">
                <div class="ic ic-blu"><i class="bi bi-people"></i></div>
                <div class="kpi-tx"><div class="v">@_rows.Count.ToString("N0")</div><div class="l">Total users</div></div>
            </div>
            <div class="kpi">
                <div class="ic ic-grn"><i class="bi bi-check-circle"></i></div>
                <div class="kpi-tx"><div class="v">@_rows.Count(r => r.User.IsActive).ToString("N0")</div><div class="l">Active</div></div>
            </div>
            <div class="kpi">
                <div class="ic ic-red"><i class="bi bi-slash-circle"></i></div>
                <div class="kpi-tx"><div class="v">@_rows.Count(r => !r.User.IsActive).ToString("N0")</div><div class="l">Inactive</div></div>
            </div>
        </div>
    }

    <div class="toolbar">
        <div class="search">
            <i class="bi bi-search"></i>
            <input placeholder="Search username, name, or email…" @bind="_search" @bind:event="oninput" />
        </div>
        <div class="chips">
            <button class="chip @(_active is null ? "on" : "")" @onclick="() => _active = null">All</button>
            <button class="chip @(_active == true ? "on" : "")" @onclick="() => _active = true">Active</button>
            <button class="chip @(_active == false ? "on" : "")" @onclick="() => _active = false">Inactive</button>
        </div>
    </div>

    @if (_rows is null)
    {
        <div class="pi-loading"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading…</div>
    }
    else
    {
        var shown = Filter(_rows, _search, _active);

        if (shown.Count == 0)
        {
            <div class="empty">
                <div class="empty-ic"><i class="bi bi-people"></i></div>
                <p>@(string.IsNullOrWhiteSpace(_search) && _active is null ? "No users yet." : "No users match your filters.")</p>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-top">
                    <span class="n">Showing <b>@shown.Count</b> of <b>@_rows.Count.ToString("N0")</b></span>
                </div>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Roles</th>
                                <th class="c" style="width:110px">Status</th>
                                <th style="width:130px">Created</th>
                                <th class="text-end pe-3" style="width:120px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in shown)
                            {
                                <tr>
                                    <td>
                                        <div class="u-cell">
                                            <div class="u-avatar @AvatarClass(row.User.DisplayName)">@Initials(row.User.DisplayName)</div>
                                            <div class="u-id">
                                                <div class="nm">@row.User.DisplayName</div>
                                                <div class="un">@("@" + row.User.UserName)</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="code">@(row.User.Email ?? "—")</td>
                                    <td>
                                        @if (row.Roles.Any())
                                        {
                                            @foreach (var role in row.Roles)
                                            {
                                                <span class="role-chip">@role</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="code">—</span>
                                        }
                                    </td>
                                    <td class="c"><span class="badge @(row.User.IsActive ? "b-ok" : "b-off")">@(row.User.IsActive ? "Active" : "Inactive")</span></td>
                                    <td class="code">@row.User.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</td>
                                    <td class="text-end pe-3 text-nowrap">
                                        <AuthorizeView Policy="settings.users.edit">
                                            <Authorized>
                                                <a class="btn btn-sm btn-outline-primary me-1" href="@($"/settings/users/{row.User.Id}/edit")" title="Edit"><i class="bi bi-pencil"></i></a>
                                            </Authorized>
                                        </AuthorizeView>
                                        <AuthorizeView Policy="settings.users.delete">
                                            <Authorized>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(row.User.Id, row.User.DisplayName)" title="Delete"><i class="bi bi-trash3"></i></button>
                                            </Authorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Row>? _rows;
    private string _search = string.Empty;
    private bool? _active;

    private sealed record Row(ApplicationUser User, IList<string> Roles);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var users = await UserManager.Users.OrderBy(u => u.UserName).ToListAsync();
        var rows = new List<Row>();
        foreach (var u in users)
            rows.Add(new Row(u, await UserManager.GetRolesAsync(u)));
        _rows = rows;
    }

    private async Task DeleteAsync(string id, string name)
    {
        if (!await Swal.ConfirmAsync("Delete user?", $"\"{name}\" will be permanently removed."))
            return;

        var user = await UserManager.FindByIdAsync(id);
        if (user is not null) await UserManager.DeleteAsync(user);
        await LoadAsync();
        await Swal.ToastAsync("success", "User deleted");
    }

    private static List<Row> Filter(List<Row> rows, string q, bool? active)
    {
        IEnumerable<Row> query = rows;
        if (active is not null)
            query = query.Where(r => r.User.IsActive == active);
        if (!string.IsNullOrWhiteSpace(q))
            query = query.Where(r =>
                (r.User.UserName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                r.User.DisplayName.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (r.User.Email ?? "").Contains(q, StringComparison.OrdinalIgnoreCase));
        return query.ToList();
    }

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var p = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length >= 2
            ? $"{char.ToUpper(p[0][0])}{char.ToUpper(p[^1][0])}"
            : char.ToUpper(name[0]).ToString();
    }

    private static string AvatarClass(string name)
    {
        var cs = new[] { "av-blue", "av-green", "av-purple", "av-orange", "av-teal" };
        if (string.IsNullOrEmpty(name)) return cs[0];
        var h = 0;
        foreach (var c in name) h += c;
        return cs[Math.Abs(h) % cs.Length];
    }
}
