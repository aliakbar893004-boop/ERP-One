@page "/dashboard"
@rendermode InteractiveServer
@using System.Globalization
@using ErpOne.Application.Dashboard
@using ErpOne.Application.Products
@using ErpOne.Domain.Entities
@inject IDashboardService DashboardService
@inject NavigationManager Nav

<PageTitle>Dashboard</PageTitle>

<div class="dash">
    <header class="dash-top">
        <div>
            <div class="dash-greet">@_greeting</div>
            <h1>Dashboard</h1>
        </div>
        <span class="dash-date">@_dateLabel</span>
    </header>

    @if (_data is null)
    {
        <div class="dash-loading"><div class="spinner-border spinner-border-sm me-2" role="status"></div>Loading summary…</div>
    }
    else
    {
        @* ── KPI: hero omzet (accent) membentang + 4 tile vibrant (Spektrum) ── *@
        <div class="kpis">
            <div class="k-hero" @onclick="@(() => Nav.NavigateTo("/reports/sales"))">
                <i class="bi bi-graph-up-arrow hero-wm" aria-hidden="true"></i>
                <svg class="hero-spark" viewBox="0 0 84 30" preserveAspectRatio="none" aria-hidden="true">
                    <polyline points="@Spark(_data.Kpis.RevenueTrend, 84, 30)" fill="none" stroke="rgba(255,255,255,.8)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
                </svg>
                <div class="hero-lbl">Today's Revenue</div>
                <div class="hero-v">Rp @_data.Kpis.TodayRevenue.ToString("N0")</div>
                <div class="hero-sub">
                    <span>@_data.Kpis.TodayTxnCount transactions</span>
                    @if (_data.Kpis.TodayTxnCount > 0)
                    {
                        <span>· avg Rp @((_data.Kpis.TodayRevenue / _data.Kpis.TodayTxnCount).ToString("N0"))</span>
                    }
                    <span class="hero-delta">· @_revDelta.txt</span>
                </div>
            </div>

            <div class="kt kt-violet" @onclick="@(() => Nav.NavigateTo("/reports/sales"))">
                <i class="bi bi-calendar3 kt-wm" aria-hidden="true"></i>
                <div class="kt-lbl">Revenue This Month</div>
                <div class="kt-v">Rp @_data.Kpis.MonthRevenue.ToString("N0")</div>
                <div class="kt-sub">month to date · @_monthLabel</div>
            </div>
            <div class="kt kt-cyan" @onclick="@(() => Nav.NavigateTo("/reports/sales"))">
                <i class="bi bi-receipt-cutoff kt-wm" aria-hidden="true"></i>
                <div class="kt-lbl">Transactions This Month</div>
                <div class="kt-v">@_data.Kpis.MonthTxnCount.ToString("N0")</div>
                <div class="kt-sub">@_data.Kpis.TodayTxnCount today</div>
            </div>
            <div class="kt kt-amber" @onclick="@(() => Nav.NavigateTo("/finance/ar-invoices"))">
                <i class="bi bi-arrow-down-left-circle kt-wm" aria-hidden="true"></i>
                <div class="kt-lbl">Receivables Due</div>
                <div class="kt-v">Rp @_data.Kpis.ArDue.ToString("N0")</div>
                <div class="kt-sub">overdue &amp; due ≤ 7 days</div>
            </div>
            <div class="kt kt-rose" @onclick="@(() => Nav.NavigateTo("/finance/ap-invoices"))">
                <i class="bi bi-arrow-up-right-circle kt-wm" aria-hidden="true"></i>
                <div class="kt-lbl">Payables Due</div>
                <div class="kt-v">Rp @_data.Kpis.ApDue.ToString("N0")</div>
                <div class="kt-sub">overdue &amp; due ≤ 7 days</div>
            </div>
        </div>

        @* ── Approvals + Receivables aging ── *@
        <div class="cols">
            <div class="card">
                <div class="ch clickable" @onclick="@(() => Nav.NavigateTo("/transactions/purchase-orders"))">
                    <i class="bi bi-hourglass-split"></i>Awaiting Approval
                    <span class="pill">@(_data.Pending.PoPendingCount + _data.Pending.SoPendingCount)</span>
                </div>
                <div class="cb p0">
                    @if (_data.Pending.PoPending.Count == 0 && _data.Pending.SoPending.Count == 0)
                    {
                        <div class="empty"><i class="bi bi-check2-circle me-1"></i>Nothing waiting for approval.</div>
                    }
                    else
                    {
                        <table class="dtable">
                            <tbody>
                                @foreach (var r in _data.Pending.PoPending)
                                {
                                    @ApprovalRow("PO", "tag-po", r, "/transactions/purchase-orders")
                                }
                                @foreach (var r in _data.Pending.SoPending)
                                {
                                    @ApprovalRow("SO", "tag-so", r, "/transactions/sales-orders")
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            @AgingCard("Receivables Aging", "bi-arrow-down-left-circle", _data.ArAging)
        </div>

        @* ── Low stock + Payables aging ── *@
        <div class="cols">
            <div class="card">
                <div class="ch"><i class="bi bi-clipboard2-pulse-fill"></i>Low / Out of Stock
                    <span class="muted ms-2 fw-normal" style="text-transform:none;letter-spacing:0">(≤ 5 pcs)</span></div>
                <div class="cb p0">
                    @if (_data.Stock.LowStock.Count == 0)
                    {
                        <div class="empty"><i class="bi bi-check2-circle me-1"></i>All products are well stocked.</div>
                    }
                    else
                    {
                        <table class="dtable">
                            <thead>
                                <tr><th style="width:48px"></th><th>SKU</th><th>Name</th><th class="te">Stock</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _data.Stock.LowStock)
                                {
                                    <tr @onclick="@(() => GoToProduct(item.Id))">
                                        <td>
                                            @if (item.ImageUrl is not null)
                                            {
                                                <img src="@item.ImageUrl" class="thumb" alt="@item.Name" />
                                            }
                                            else
                                            {
                                                <div class="thumb thumb-empty"><i class="bi bi-image"></i></div>
                                            }
                                        </td>
                                        <td class="code">@item.Sku</td>
                                        <td class="fw-medium">@item.Name</td>
                                        <td class="te"><span class="stk @(item.Stock == 0 ? "z" : "lo")">@item.Stock</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            @AgingCard("Payables Aging", "bi-arrow-up-right-circle", _data.ApAging)
        </div>

        @* ── Inventory breakdown ── *@
        <div class="sec-label"><span>Inventory</span></div>
        <div class="cols even">
            <div class="card">
                <div class="ch"><i class="bi bi-pie-chart-fill"></i>Products by Status</div>
                <div class="cb">
                    @if (_data.Stock.TotalProducts == 0)
                    {
                        <div class="muted-note">No products yet.</div>
                    }
                    else
                    {
                        @foreach (var s in Enum.GetValues<ProductStatus>())
                        {
                            var count = _data.Stock.ByStatus.FirstOrDefault(x => x.Status == s)?.Count ?? 0;
                            var pct = _data.Stock.TotalProducts == 0 ? 0 : (int)Math.Round(count * 100.0 / _data.Stock.TotalProducts);
                            <div class="row-stat">
                                <div class="row-stat-t"><span><span class="dot @StatusDot(s)"></span>@s</span><span class="muted">@count · @pct%</span></div>
                                <div class="bar"><i class="@StatusBar(s)" style="width:@pct%"></i></div>
                            </div>
                        }
                        <div class="mini-row">
                            <div class="mini @(_data.Stock.OutOfStockCount > 0 ? "danger" : "ok")">
                                <div class="mini-v">@_data.Stock.OutOfStockCount</div>
                                <div class="mini-l"><i class="bi bi-x-octagon me-1"></i>Out of stock</div>
                            </div>
                            <div class="mini @(_data.Stock.LowStockCount > 0 ? "warn" : "ok")">
                                <div class="mini-v">@_data.Stock.LowStockCount</div>
                                <div class="mini-l"><i class="bi bi-exclamation-triangle me-1"></i>Low stock</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card">
                <div class="ch"><i class="bi bi-bar-chart-line-fill"></i>Stock by Category</div>
                <div class="cb">
                    @if (_data.Stock.ByCategory.Count == 0)
                    {
                        <div class="muted-note">No categorized products yet.</div>
                    }
                    else
                    {
                        var maxStock = _data.Stock.ByCategory.Max(c => c.TotalStock);
                        @foreach (var c in _data.Stock.ByCategory)
                        {
                            var pct = maxStock == 0 ? 0 : (int)Math.Round(c.TotalStock * 100.0 / maxStock);
                            <div class="row-stat">
                                <div class="row-stat-t"><span class="fw-medium">@c.CategoryName</span><span class="muted">@c.TotalStock pcs · @c.ProductCount item</span></div>
                                <div class="bar"><i class="grad-accent" style="width:@(Math.Max(pct, 3))%"></i></div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private OperationalDashboardDto? _data;
    private string _dateLabel = "";
    private string _monthLabel = "";
    private string _greeting = "";
    private (string cls, string txt) _revDelta;
    private static readonly CultureInfo Inv = CultureInfo.InvariantCulture;
    private static readonly CultureInfo En = CultureInfo.GetCultureInfo("en-US");

    protected override async Task OnInitializedAsync()
    {
        var now = DateTime.Now;
        var t = now.Date;
        _dateLabel = t.ToString("dddd, d MMMM yyyy", En);
        _monthLabel = t.ToString("MMMM yyyy", En);
        _greeting = now.Hour < 12 ? "Good morning" : now.Hour < 18 ? "Good afternoon" : "Good evening";
        _data = await DashboardService.GetAsync(t);
        _revDelta = Delta(_data.Kpis.TodayRevenue, _data.Kpis.YesterdayRevenue);
    }

    private void GoToProduct(int id) => Nav.NavigateTo($"/master/products/{id}/edit");

    private static (string cls, string txt) Delta(decimal today, decimal yesterday)
    {
        if (yesterday > 0)
        {
            var p = (today - yesterday) / yesterday * 100m;
            var up = p >= 0;
            return (up ? "up" : "down", (up ? "▲ " : "▼ ") + Math.Abs(p).ToString("0") + "% vs yesterday");
        }
        return today > 0 ? ("up", "▲ new") : ("flat", "—");
    }

    // Build an SVG polyline point string normalised into a 64×26 viewBox.
    private static string Spark(IReadOnlyList<decimal> vals, double w = 64, double h = 26, double pad = 3)
    {
        if (vals.Count == 0) return "";
        double min = (double)vals.Min(), max = (double)vals.Max(), range = max - min;
        int n = vals.Count;
        var pts = new string[n];
        for (var i = 0; i < n; i++)
        {
            var x = n == 1 ? w / 2 : i * w / (n - 1);
            var y = range == 0 ? h / 2 : (h - pad) - ((double)vals[i] - min) / range * (h - 2 * pad);
            pts[i] = x.ToString("0.#", Inv) + "," + y.ToString("0.#", Inv);
        }
        return string.Join(" ", pts);
    }

    private RenderFragment ApprovalRow(string tag, string tagCls, PendingDocRow r, string href) => __builder =>
    {
        <tr @onclick="@(() => Nav.NavigateTo(href))">
            <td style="width:44px"><span class="tag @tagCls">@tag</span></td>
            <td class="po-no">@r.Number</td>
            <td class="fw-medium">@r.Party</td>
            <td class="te fw-medium">Rp @r.Total.ToString("N0")</td>
        </tr>
    };

    private RenderFragment AgingCard(string title, string icon, AgingBuckets a) => __builder =>
    {
        <div class="card">
            <div class="ch"><i class="bi @icon"></i>@title<span class="tot">Rp @a.Total.ToString("N0")</span></div>
            <div class="cb">
                @if (a.Total == 0)
                {
                    <div class="muted-note">No open bills.</div>
                }
                else
                {
                    @AgeBar("0–30 days", a.Current, a.Total, "s0")
                    @AgeBar("31–60 days", a.D31_60, a.Total, "s1")
                    @AgeBar("61–90 days", a.D61_90, a.Total, "s2")
                    @AgeBar("90+ days", a.D90Plus, a.Total, "s3")
                }
            </div>
        </div>
    };

    private RenderFragment AgeBar(string label, decimal value, decimal total, string cls) => __builder =>
    {
        var pct = total == 0 ? 0 : (int)Math.Round((double)(value / total) * 100);
        <div class="row-stat @(value > 0 ? "" : "off")">
            <div class="row-stat-t"><span>@label</span><span class="muted">Rp @value.ToString("N0")</span></div>
            <div class="bar"><i class="@cls" style="width:@(Math.Max(pct, value > 0 ? 3 : 0))%"></i></div>
        </div>
    };

    private static string StatusDot(ProductStatus s) => "dot-" + s.ToString().ToLowerInvariant();

    private static string StatusBar(ProductStatus s) => s switch
    {
        ProductStatus.Aktif => "grad-green",
        ProductStatus.Nonaktif => "grad-grey",
        ProductStatus.Habis => "grad-amber",
        ProductStatus.Arsip => "grad-dark",
        _ => "grad-grey"
    };
}
