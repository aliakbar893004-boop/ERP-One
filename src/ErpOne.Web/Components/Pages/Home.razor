@page "/"
@rendermode InteractiveServer

<PageTitle>ERP_One</PageTitle>

<section class="landing">
    <p class="landing-eyebrow">ERP_One</p>
    <h1 class="landing-title">Welcome <span class="accent">back</span></h1>
    <p class="landing-sub">Choose a module to get started.</p>

    <div class="landing-grid">
        <AuthorizeView Policy="dashboard.index"><Authorized>
            <a class="lc" style="--c:#0E9F6E" href="/dashboard">
                <span class="lc-ic"><i class="bi bi-speedometer2"></i></span>
                <h3>Dashboard</h3>
                <p>Daily performance and what needs attention.</p>
                <span class="lc-go">Open Dashboard <i class="bi bi-arrow-right"></i></span>
            </a>
        </Authorized></AuthorizeView>

        <AuthorizeView Policy="master.products.index"><Authorized>
            <a class="lc" style="--c:#3771EC" href="/master/products">
                <span class="lc-ic"><i class="bi bi-box-seam-fill"></i></span>
                <h3>Products</h3>
                <p>Manage products, variants and categories.</p>
                <span class="lc-go">Open Products <i class="bi bi-arrow-right"></i></span>
            </a>
        </Authorized></AuthorizeView>

        <AuthorizeView Policy="transactions.hub.index"><Authorized>
            <a class="lc" style="--c:#7C3AED" href="/transactions">
                <span class="lc-ic"><i class="bi bi-grid-1x2-fill"></i></span>
                <h3>Transactions</h3>
                <p>Purchase orders, sales orders and deliveries.</p>
                <span class="lc-go">Open Transactions <i class="bi bi-arrow-right"></i></span>
            </a>
        </Authorized></AuthorizeView>

        <AuthorizeView Policy="cashier.pos.create"><Authorized>
            <a class="lc" style="--c:#EA580C" href="/cashier/pos">
                <span class="lc-ic"><i class="bi bi-bag-check-fill"></i></span>
                <h3>Point of Sale</h3>
                <p>Cashier checkout and shift sessions.</p>
                <span class="lc-go">Open POS <i class="bi bi-arrow-right"></i></span>
            </a>
        </Authorized></AuthorizeView>

        <AuthorizeView Policy="finance.ar-invoices.index"><Authorized>
            <a class="lc" style="--c:#E11D48" href="/finance/ar-invoices">
                <span class="lc-ic"><i class="bi bi-wallet2"></i></span>
                <h3>Finance</h3>
                <p>Invoices, payments and expenses.</p>
                <span class="lc-go">Open Finance <i class="bi bi-arrow-right"></i></span>
            </a>
        </Authorized></AuthorizeView>

        <AuthorizeView Policy="reports.sales.index"><Authorized>
            <a class="lc" style="--c:#0D9488" href="/reports/sales">
                <span class="lc-ic"><i class="bi bi-graph-up-arrow"></i></span>
                <h3>Reports</h3>
                <p>Sales, inventory and financial reports.</p>
                <span class="lc-go">Open Reports <i class="bi bi-arrow-right"></i></span>
            </a>
        </Authorized></AuthorizeView>
    </div>
</section>
