@page "/"
@rendermode InteractiveServer
@inject IProductService ProductService

<PageTitle>Dashboard</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h4 mb-0 fw-semibold">Dashboard</h1>
        <span class="text-muted small">Product &amp; stock overview</span>
    </div>
    <a class="btn btn-outline-primary btn-sm" href="/master/products">
        <i class="bi bi-box-seam me-1"></i>Manage products
    </a>
</div>

@if (_data is null)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>Loading...
    </div>
}
else
{
    <!-- ── Stat cards ─────────────────────────────────────────── -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card grad-blue">
                <div class="stat-icon"><i class="bi bi-box-seam-fill"></i></div>
                <div class="stat-meta">
                    <div class="stat-value">@_data.TotalProducts.ToString("N0")</div>
                    <div class="stat-label">Total Products</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card grad-green">
                <div class="stat-icon"><i class="bi bi-boxes"></i></div>
                <div class="stat-meta">
                    <div class="stat-value">@_data.TotalStock.ToString("N0")</div>
                    <div class="stat-label">Total Stock</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card grad-purple">
                <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
                <div class="stat-meta">
                    <div class="stat-value">Rp @_data.InventoryValue.ToString("N0")</div>
                    <div class="stat-label">Inventory Value</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card grad-amber">
                <div class="stat-icon"><i class="bi bi-tags-fill"></i></div>
                <div class="stat-meta">
                    <div class="stat-value">@_data.TotalCategories.ToString("N0")</div>
                    <div class="stat-label">Categories</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- ── Status breakdown + alerts ──────────────────────────── -->
        <div class="col-12 col-lg-5">
            <div class="d-card mb-4">
                <div class="d-card-head"><i class="bi bi-pie-chart-fill me-2"></i>Products by Status</div>
                <div class="d-card-body">
                    @if (_data.TotalProducts == 0)
                    {
                        <div class="text-muted small">No products yet.</div>
                    }
                    else
                    {
                        @foreach (var s in Enum.GetValues<ProductStatus>())
                        {
                            var count = _data.ByStatus.FirstOrDefault(x => x.Status == s)?.Count ?? 0;
                            var pct = _data.TotalProducts == 0 ? 0 : (int)Math.Round(count * 100.0 / _data.TotalProducts);
                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span><span class="dot @StatusDot(s)"></span>@s</span>
                                    <span class="text-muted">@count · @pct%</span>
                                </div>
                                <div class="bar"><div class="bar-fill @StatusBar(s)" style="width:@pct%"></div></div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="row g-3">
                <div class="col-6">
                    <div class="mini-alert @(_data.OutOfStockCount > 0 ? "danger" : "ok")">
                        <div class="mini-value">@_data.OutOfStockCount</div>
                        <div class="mini-label"><i class="bi bi-x-octagon me-1"></i>Out of stock</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="mini-alert @(_data.LowStockCount > 0 ? "warn" : "ok")">
                        <div class="mini-value">@_data.LowStockCount</div>
                        <div class="mini-label"><i class="bi bi-exclamation-triangle me-1"></i>Low stock</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Stock by category ──────────────────────────────────── -->
        <div class="col-12 col-lg-7">
            <div class="d-card h-100">
                <div class="d-card-head"><i class="bi bi-bar-chart-line-fill me-2"></i>Stock by Category</div>
                <div class="d-card-body">
                    @if (_data.ByCategory.Count == 0)
                    {
                        <div class="text-muted small">No categorized products yet.</div>
                    }
                    else
                    {
                        var maxStock = _data.ByCategory.Max(c => c.TotalStock);
                        @foreach (var c in _data.ByCategory)
                        {
                            var pct = maxStock == 0 ? 0 : (int)Math.Round(c.TotalStock * 100.0 / maxStock);
                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="fw-medium">@c.CategoryName</span>
                                    <span class="text-muted">@c.TotalStock pcs · @c.ProductCount item(s)</span>
                                </div>
                                <div class="bar"><div class="bar-fill grad-blue" style="width:@(Math.Max(pct, 3))%"></div></div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- ── Low stock table ────────────────────────────────────── -->
        <div class="col-12">
            <div class="d-card">
                <div class="d-card-head">
                    <i class="bi bi-clipboard2-pulse-fill me-2"></i>Low / Out of Stock
                    <span class="text-muted fw-normal ms-2 small">(≤ 5 pcs)</span>
                </div>
                <div class="d-card-body p-0">
                    @if (_data.LowStock.Count == 0)
                    {
                        <div class="text-muted small p-4 text-center">
                            <i class="bi bi-check2-circle me-1"></i>All products are well stocked.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3" style="width:56px"></th>
                                        <th>SKU</th>
                                        <th>Name</th>
                                        <th class="text-center">Status</th>
                                        <th class="text-end pe-3">Stock</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _data.LowStock)
                                    {
                                        <tr style="cursor:pointer" @onclick="@(() => GoToProduct(item.Id))">
                                            <td class="ps-3">
                                                @if (item.ImageUrl is not null)
                                                {
                                                    <img src="@item.ImageUrl" class="thumb" alt="@item.Name" />
                                                }
                                                else
                                                {
                                                    <div class="thumb thumb-empty"><i class="bi bi-image"></i></div>
                                                }
                                            </td>
                                            <td class="text-muted small text-nowrap">@item.Sku</td>
                                            <td class="fw-medium">@item.Name</td>
                                            <td class="text-center"><span class="badge @StatusBadge(item.Status)">@item.Status</span></td>
                                            <td class="text-end pe-3">
                                                <span class="badge @(item.Stock == 0 ? "bg-danger" : "bg-warning text-dark")">
                                                    @item.Stock
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
}

@code {
    private ProductDashboardDto? _data;

    [Inject] private NavigationManager Nav { get; set; } = default!;

    protected override async Task OnInitializedAsync() =>
        _data = await ProductService.GetDashboardAsync();

    private void GoToProduct(int id) => Nav.NavigateTo($"/master/products/{id}/edit");

    private static string StatusDot(ProductStatus s) => "dot-" + s.ToString().ToLowerInvariant();

    private static string StatusBar(ProductStatus s) => s switch
    {
        ProductStatus.Aktif => "grad-green",
        ProductStatus.Nonaktif => "grad-grey",
        ProductStatus.Habis => "grad-amber",
        ProductStatus.Arsip => "grad-dark",
        _ => "grad-grey"
    };

    private static string StatusBadge(ProductStatus s) => s switch
    {
        ProductStatus.Aktif => "bg-success-subtle text-success-emphasis",
        ProductStatus.Nonaktif => "bg-secondary-subtle text-secondary-emphasis",
        ProductStatus.Habis => "bg-warning-subtle text-warning-emphasis",
        ProductStatus.Arsip => "bg-dark-subtle text-dark-emphasis",
        _ => "bg-light text-muted"
    };
}
