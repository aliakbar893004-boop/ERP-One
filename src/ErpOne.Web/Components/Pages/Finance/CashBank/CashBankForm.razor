@page "/finance/cash-bank/new"
@page "/finance/cash-bank/{Id:int}/edit"
@attribute [Authorize]
@rendermode InteractiveServer
@using FluentValidation
@inject ICashBankAccountService AccountService
@inject ICurrencyService CurrencyService
@inject IAuthorizationService Auth
@inject NavigationManager Nav

<PageTitle>@Title</PageTitle>

<div class="cf">
    <div class="cf-top">
        <div class="crumbs">
            <a href="/finance/cash-bank">Finance</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/finance/cash-bank">Cash &amp; Bank</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(Id is null ? "New" : "Edit")</span>
        </div>
        <h1>@Title</h1>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_notFound)
    {
        <div class="cf-alert warn"><i class="bi bi-exclamation-triangle"></i> Account not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="cf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="cf-wrap">
            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-bank"></i></span>
                    <div class="hd-tx">
                        <h2>Account information</h2>
                        <p>A cash or bank account used for payments and receipts.</p>
                    </div>
                </div>
                <div class="card-b">
                    <div class="grid">
                        <div class="f c3">
                            <label class="fl">Code <span class="req">*</span></label>
                            <input class="ctl mono up @(_codeError is not null ? "bad" : "")" placeholder="CASH" maxlength="20" @bind="_code" @bind:event="oninput" />
                            @if (_codeError is not null) { <div class="err-txt">@_codeError</div> }
                        </div>
                        <div class="f c6">
                            <label class="fl">Name <span class="req">*</span></label>
                            <input class="ctl @(_nameError is not null ? "bad" : "")" placeholder="Main Cash" maxlength="100" @bind="_name" @bind:event="oninput" />
                            @if (_nameError is not null) { <div class="err-txt">@_nameError</div> }
                        </div>
                        <div class="f c3">
                            <label class="fl">Type <span class="req">*</span></label>
                            <select class="ctl" @bind="_type">
                                <option value="Cash">Cash</option>
                                <option value="Bank">Bank</option>
                            </select>
                        </div>
                        <div class="f c3">
                            <label class="fl">Currency</label>
                            <select class="ctl" @bind="_currency">
                                @foreach (var c in _currencies)
                                {
                                    <option value="@c.Code">@c.Code — @c.Name</option>
                                }
                            </select>
                        </div>
                        <div class="f c3">
                            <label class="fl">Opening balance</label>
                            <input type="number" step="0.01" min="0" class="ctl mono" @bind="_openingBalance" />
                        </div>
                        @if (_type == "Bank")
                        {
                            <div class="f c6">
                                <label class="fl">Bank name</label>
                                <input class="ctl" maxlength="100" @bind="_bankName" />
                            </div>
                            <div class="f c6">
                                <label class="fl">Account number</label>
                                <input class="ctl mono" maxlength="50" @bind="_accountNumber" />
                            </div>
                            <div class="f c6">
                                <label class="fl">Account holder</label>
                                <input class="ctl" maxlength="100" @bind="_accountHolder" />
                            </div>
                        }
                        <div class="f c12 d-flex align-items-end">
                            <label class="fl-check"><input type="checkbox" @bind="_isActive" /> Active</label>
                        </div>
                    </div>
                </div>
            </section>

            <div class="pf-footer">
                <div class="in">
                    <span class="note"><span class="req">*</span> required fields</span>
                    <a class="btn btn-ghost" href="/finance/cash-bank"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                        else { <i class="bi bi-check2"></i> }
                        Save account
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private string _code = string.Empty;
    private string _name = string.Empty;
    private string _type = "Cash";
    private string _currency = "IDR";
    private decimal _openingBalance;
    private string? _bankName, _accountNumber, _accountHolder;
    private bool _isActive = true;
    private IReadOnlyList<CurrencyDto> _currencies = [];
    private bool _loading = true, _saving, _notFound;
    private string? _error, _codeError, _nameError;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string Title => Id is null ? "Add Account" : "Edit Account";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        var perm = Id is null ? AppMenus.Perm("finance.cash-bank", "create") : AppMenus.Perm("finance.cash-bank", "edit");
        if (!(await Auth.AuthorizeAsync(state.User, perm)).Succeeded)
        {
            Nav.NavigateTo("/finance/cash-bank");
            return;
        }

        _currencies = await CurrencyService.GetActiveAsync();

        if (Id is int id)
        {
            var a = await AccountService.GetByIdAsync(id);
            if (a is null) _notFound = true;
            else
            {
                _code = a.Code; _name = a.Name; _type = a.Type; _currency = a.Currency;
                _openingBalance = a.OpeningBalance; _bankName = a.BankName;
                _accountNumber = a.AccountNumber; _accountHolder = a.AccountHolder; _isActive = a.IsActive;
            }
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _error = _codeError = _nameError = null;
        _saving = true;
        try
        {
            if (Id is int id)
                await AccountService.UpdateAsync(id, new UpdateCashBankAccountRequest(_code, _name, _type, _currency, _openingBalance, _bankName, _accountNumber, _accountHolder, _isActive));
            else
                await AccountService.CreateAsync(new CreateCashBankAccountRequest(_code, _name, _type, _currency, _openingBalance, _bankName, _accountNumber, _accountHolder, _isActive));

            Nav.NavigateTo("/finance/cash-bank");
        }
        catch (ValidationException ex)
        {
            foreach (var e in ex.Errors)
            {
                if (e.PropertyName == nameof(CreateCashBankAccountRequest.Code)) _codeError = e.ErrorMessage;
                else if (e.PropertyName == nameof(CreateCashBankAccountRequest.Name)) _nameError = e.ErrorMessage;
                else _error = e.ErrorMessage;
            }
        }
        finally { _saving = false; }
    }
}
