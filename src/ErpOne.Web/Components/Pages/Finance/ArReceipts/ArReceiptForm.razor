@page "/finance/ar-receipts/new"
@attribute [Authorize(Policy = "finance.ar-receipts.create")]
@rendermode InteractiveServer
@using FluentValidation
@inject ICustomerReceiptService ReceiptService
@inject ICustomerService CustomerService
@inject ICashBankAccountService AccountService
@inject NavigationManager Nav

<PageTitle>New Customer Receipt</PageTitle>

<div class="cf">
    <div class="cf-top">
        <div class="crumbs">
            <a href="/finance/ar-receipts">Finance</a><i class="bi bi-chevron-right"></i>
            <a href="/finance/ar-receipts">Customer Receipts</a><i class="bi bi-chevron-right"></i>
            <span class="here">New</span>
        </div>
        <h1>New Customer Receipt</h1>
    </div>

    @if (_loading) { <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div> }
    else
    {
        @if (_error is not null) { <div class="cf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div> }

        <div class="cf-wrap">
            <section class="card">
                <div class="card-h"><span class="hd-ic"><i class="bi bi-cash-stack"></i></span><div class="hd-tx"><h2>Receipt</h2><p>Record money received from a customer against outstanding invoices.</p></div></div>
                <div class="card-b">
                    <div class="grid">
                        <div class="f c6">
                            <label class="fl">Customer <span class="req">*</span></label>
                            <select class="ctl" @bind="_customerId" @bind:after="OnCustomerChangedAsync">
                                <option value="0">— Select customer —</option>
                                @foreach (var c in _customers) { <option value="@c.Id">@c.Code — @c.Name</option> }
                            </select>
                        </div>
                        <div class="f c6">
                            <label class="fl">Cash / bank account <span class="req">*</span></label>
                            <select class="ctl" @bind="_accountId">
                                <option value="0">— Select account —</option>
                                @foreach (var a in _accounts) { <option value="@a.Id">@a.Code — @a.Name (@a.Currency)</option> }
                            </select>
                        </div>
                        <div class="f c4">
                            <label class="fl">Receipt date <span class="req">*</span></label>
                            <input type="date" class="ctl" @bind="_receiptDate" />
                        </div>
                        <div class="f c8">
                            <label class="fl">Notes</label>
                            <input class="ctl" maxlength="500" @bind="_notes" placeholder="Optional" />
                        </div>
                    </div>
                </div>
            </section>

            <section class="card">
                <div class="card-h"><span class="hd-ic"><i class="bi bi-receipt-cutoff"></i></span><div class="hd-tx"><h2>Allocate to invoices</h2><p>Enter the amount received against each outstanding invoice.</p></div></div>
                <div class="card-b">
                    @if (_customerId == 0) { <div class="text-muted small">Select a customer to list outstanding invoices.</div> }
                    else if (_rows.Count == 0) { <div class="text-muted small">No outstanding invoices for this customer.</div> }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small">@_rows.Count outstanding invoice(s)</span>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ReceiveAll"><i class="bi bi-check2-all"></i> Receive all</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearAll"><i class="bi bi-eraser"></i> Clear</button>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead class="table-light"><tr><th>Invoice</th><th>Due</th><th class="text-end">Grand total</th><th class="text-end">Outstanding</th><th class="text-end" style="width:210px">Receive amount</th></tr></thead>
                                <tbody>
                                    @foreach (var r in _rows)
                                    {
                                        <tr class="@(r.Amount > 0 ? "table-active" : "")">
                                            <td class="mono">@r.Inv.InvoiceNumber</td>
                                            <td class="text-nowrap">@r.Inv.DueDate.ToString("d MMM yyyy") <span class="badge @AgingClass(r.Inv.DueDate)">@AgingLabel(r.Inv.DueDate)</span></td>
                                            <td class="text-end mono">@r.Inv.GrandTotal.ToString("N2")</td>
                                            <td class="text-end mono">@r.Inv.Outstanding.ToString("N2")</td>
                                            <td>
                                                <div class="pay-input">
                                                    <input type="number" step="0.01" min="0" max="@r.Inv.Outstanding" class="ctl mono" @bind="r.Amount" />
                                                    <button type="button" class="btn-full" title="Receive full outstanding" @onclick="@(() => r.Amount = r.Inv.Outstanding)">Full</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-end mt-2">
                            <div class="pay-summary">
                                <div><span class="k">@_rows.Count(r => r.Amount > 0) invoice(s) allocated</span></div>
                                <div class="grand"><span>Total received</span><span class="mono">@Total().ToString("N2")</span></div>
                                @if (SelectedAccount() is { } acc)
                                {
                                    <div><span>@acc.Name balance</span><span class="mono">@acc.CurrentBalance.ToString("N2")</span></div>
                                    <div><span>After receipt</span><span class="mono">@((acc.CurrentBalance + Total()).ToString("N2"))</span></div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>

            <div class="pf-footer">
                <div class="in">
                    <span class="note"><span class="req">*</span> required fields</span>
                    <a class="btn btn-ghost" href="/finance/ar-receipts"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(_saving || _accountId == 0 || Total() <= 0)">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> } else { <i class="bi bi-check2"></i> }
                        Post receipt
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private sealed class Row { public OpenInvoiceDto Inv { get; set; } = default!; public decimal Amount { get; set; } }

    private int _customerId, _accountId;
    private DateTime _receiptDate = DateTime.Today;
    private string? _notes;
    private IReadOnlyList<CustomerDto> _customers = [];
    private IReadOnlyList<CashBankAccountDto> _accounts = [];
    private List<Row> _rows = [];
    private bool _loading = true, _saving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomerService.GetAllAsync();
        _accounts = await AccountService.GetActiveAsync();
        _loading = false;
    }

    private async Task OnCustomerChangedAsync() =>
        _rows = _customerId == 0 ? [] : (await ReceiptService.GetOpenInvoicesAsync(_customerId)).Select(i => new Row { Inv = i }).ToList();

    private decimal Total() => _rows.Sum(r => r.Amount);
    private void ReceiveAll() { foreach (var r in _rows) r.Amount = r.Inv.Outstanding; }
    private void ClearAll() { foreach (var r in _rows) r.Amount = 0m; }
    private CashBankAccountDto? SelectedAccount() => _accounts.FirstOrDefault(a => a.Id == _accountId);

    private static string AgingLabel(DateTime due)
    {
        var days = (due.Date - DateTime.Today).Days;
        return days < 0 ? $"{-days}d overdue" : days == 0 ? "due today" : $"in {days}d";
    }
    private static string AgingClass(DateTime due)
    {
        var days = (due.Date - DateTime.Today).Days;
        return days < 0 ? "bg-danger-subtle text-danger-emphasis" : days <= 7 ? "bg-warning-subtle text-warning-emphasis" : "bg-secondary-subtle text-secondary-emphasis";
    }

    private async Task SaveAsync()
    {
        _error = null; _saving = true;
        try
        {
            var allocations = _rows.Where(r => r.Amount > 0).Select(r => new ReceiptAllocationInput(r.Inv.CustomerInvoiceId, r.Amount)).ToList();
            await ReceiptService.CreateAsync(new CreateCustomerReceiptRequest(_customerId, _accountId, _receiptDate, _notes, allocations));
            Nav.NavigateTo("/finance/ar-receipts");
        }
        catch (ValidationException ex) { _error = ex.Errors.FirstOrDefault()?.ErrorMessage ?? "Validation failed."; }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }
}
