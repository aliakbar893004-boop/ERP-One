@page "/finance/expenses/{Id:int}"
@attribute [Authorize(Policy = "finance.expenses.index")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using ErpOne.Application.Approvals
@inject IExpenseService ExpenseService
@inject IApprovalChainService ApprovalChains
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<ApplicationRole> RoleManager
@inject SwalService Swal

<PageTitle>@(_e?.ExpenseNumber ?? "Expense")</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
}
else if (_e is null)
{
    <div class="pf"><div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> Expense not found.</div></div>
}
else
{
    <div class="pf">
        <div class="pf-top">
            <div class="crumbs"><a href="/finance/expenses">Expenses</a><i class="bi bi-chevron-right"></i><span class="here">@_e.ExpenseNumber</span></div>
        </div>
        <div class="pd-head">
            <h1>@_e.ExpenseNumber</h1>
            <span class="badge @(_e.Status == "Voided" ? "b-danger" : "b-done")">@_e.Status</span>
            <div class="actions">
                @if (_e.Status == "Posted")
                {
                    <AuthorizeView Policy="finance.expenses.void"><Authorized>
                        <button class="btn btn-danger btn-sm" @onclick="OpenVoid" disabled="@_busy"><i class="bi bi-x-octagon"></i> Void</button>
                    </Authorized></AuthorizeView>
                }
            </div>
        </div>

        @if (_showVoid)
        {
            <div class="auth-overlay" @onclick="@(() => _showVoid = false)">
                <div class="auth-modal" @onclick:stopPropagation="true">
                    <h3><i class="bi bi-shield-lock"></i> Void authorization</h3>
                    <p>Enter the credentials of an authorized user to void this expense.</p>
                    @if (_voidError is not null) { <div class="pf-alert err">@_voidError</div> }
                    <label class="fl">Username</label>
                    <input class="ctl" @bind="_voidUser" autocomplete="off" />
                    <label class="fl" style="margin-top:10px">Password</label>
                    <input class="ctl" type="password" @bind="_voidPass" autocomplete="off" />
                    <div class="row-end" style="margin-top:14px">
                        <button class="btn btn-ghost btn-sm" @onclick="@(() => _showVoid = false)" disabled="@_busy">Cancel</button>
                        <button class="btn btn-danger btn-sm" @onclick="ConfirmVoidAsync" disabled="@_busy">
                            @if (_busy) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                            Authorize &amp; void
                        </button>
                    </div>
                </div>
            </div>
        }

        <section class="card">
            <div class="card-h"><span class="hd-ic"><i class="bi bi-wallet2"></i></span><h2>Expense</h2></div>
            <div class="card-b">
                <div class="info-grid">
                    <div class="info-cell"><span class="k"><i class="bi bi-tags"></i> Category</span><span class="v">@_e.CategoryName</span></div>
                    <div class="info-cell"><span class="k"><i class="bi bi-bank"></i> Paid from</span><span class="v">@_e.CashBankAccountName</span></div>
                    <div class="info-cell"><span class="k"><i class="bi bi-calendar3"></i> Date</span><span class="v">@_e.ExpenseDate.ToString("d MMM yyyy")</span></div>
                    <div class="info-cell"><span class="k"><i class="bi bi-cash-stack"></i> Amount</span><span class="v">@_e.Currency @_e.Amount.ToString("N2")</span></div>
                    <div class="info-cell"><span class="k"><i class="bi bi-person"></i> Payee</span><span class="v @(_e.Payee is null ? "muted-v" : "")">@(_e.Payee ?? "—")</span></div>
                    <div class="info-cell wide"><span class="k"><i class="bi bi-card-text"></i> Description</span><span class="v">@_e.Description</span></div>
                    @if (!string.IsNullOrWhiteSpace(_e.Notes)) { <div class="info-cell wide"><span class="k"><i class="bi bi-sticky"></i> Notes</span><span class="v">@_e.Notes</span></div> }
                </div>
            </div>
        </section>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private ExpenseDto? _e;
    private bool _loading = true, _busy, _showVoid;
    private string _voidUser = "", _voidPass = "";
    private string? _voidError;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() { _loading = true; _e = await ExpenseService.GetByIdAsync(Id); _loading = false; }

    private void OpenVoid() { _voidError = null; _voidUser = ""; _voidPass = ""; _showVoid = true; }

    private async Task ConfirmVoidAsync()
    {
        _voidError = null; _busy = true;
        try
        {
            var authName = await VerifyVoidAuthorizerAsync(_voidUser, _voidPass);
            if (authName is null) { _voidError = "Invalid credentials or user not authorized to void."; return; }
            await ExpenseService.VoidAsync(Id, authName);
            _showVoid = false; _voidUser = ""; _voidPass = "";
            await LoadAsync();
            await Swal.ToastAsync("success", "Expense voided");
        }
        catch (Exception ex) { _voidError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task<string?> VerifyVoidAuthorizerAsync(string username, string password)
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password)) return null;
        var user = await UserManager.FindByNameAsync(username.Trim());
        if (user is null || !user.IsActive) return null;
        if (!await UserManager.CheckPasswordAsync(user, password)) return null;

        var userRoles = await UserManager.GetRolesAsync(user);
        var voidRoles = (await ApprovalChains.GetByDocumentTypeAsync(ApprovalDocumentType.ExpenseVoid))
            .Select(s => s.RoleName).ToHashSet();

        var authorized = voidRoles.Count > 0 ? userRoles.Any(voidRoles.Contains) : await UserHasVoidPermissionAsync(userRoles);
        return authorized ? (user.UserName ?? username) : null;
    }

    private async Task<bool> UserHasVoidPermissionAsync(IEnumerable<string> userRoles)
    {
        var perm = AppMenus.Perm("finance.expenses", "void");
        foreach (var roleName in userRoles)
        {
            var role = await RoleManager.FindByNameAsync(roleName);
            if (role is null) continue;
            var claims = await RoleManager.GetClaimsAsync(role);
            if (claims.Any(c => c.Type == AppMenus.ClaimType && c.Value == perm)) return true;
        }
        return false;
    }
}
