@page "/cashier/sales"
@attribute [Authorize(Policy = "cashier.pos.index")]
@rendermode InteractiveServer
@using ErpOne.Application.Common
@using ErpOne.Application.PosSales
@using ErpOne.Application.PaymentMethods
@inject IPosSaleService Pos
@inject IPaymentMethodService PaymentMethods
@inject NavigationManager Nav

<PageTitle>Sales History</PageTitle>

<div class="pi">

    <div class="pi-head">
        <div>
            <nav class="crumbs"><a href="/">Home</a><span class="sep">·</span><span>Cashier</span><span class="sep">·</span><span class="here">Sales History</span></nav>
            <h1>Sales History</h1>
            <p>Direct point-of-sale transactions. Click a row for details &amp; to reprint the receipt.</p>
        </div>
        <div class="pi-actions">
            <AuthorizeView Policy="cashier.pos.create">
                <Authorized>
                    <a class="btn btn-primary" href="/cashier/pos"><i class="bi bi-bag-check-fill"></i> Open Register</a>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <div class="toolbar">
        <div class="search">
            <i class="bi bi-search"></i>
            <input placeholder="Search receipt number…" @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
        <select class="ctl" style="max-width:220px" @bind="_methodId" @bind:after="ReloadAsync">
            <option value="0">All methods</option>
            @foreach (var m in _methods) { <option value="@m.Id">@m.Name</option> }
        </select>
        <select class="ctl" style="max-width:220px" @bind="_cashierUserId" @bind:after="ReloadAsync">
            <option value="">All cashiers</option>
            @foreach (var c in _cashiers) { <option value="@c.UserId">@c.Name</option> }
        </select>
    </div>

    @if (_page is null)
    {
        <div class="pi-loading"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading…</div>
    }
    else if (_page.Total == 0)
    {
        <div class="empty">
            <div class="empty-ic"><i class="bi bi-receipt"></i></div>
            <p>No matching sales yet.</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-top">
                <span class="n">Showing <b>@((_page.Page - 1) * PageSize + 1)–@Math.Min(_page.Page * PageSize, _page.Total)</b> of <b>@_page.Total.ToString("N0")</b></span>
            </div>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Receipt No.</th>
                            <th>Date</th>
                            <th>Cashier</th>
                            <th>Method</th>
                            <th class="c">Total</th>
                            <th style="width:60px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _page.Items)
                        {
                            <tr @onclick="() => Open(item.Id)">
                                <td class="code mono">@item.SaleNumber</td>
                                <td class="code">@item.SaleDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td class="nm">@item.CashierName</td>
                                <td class="nm">@item.PaymentMethodName</td>
                                <td class="c mono">@item.GrandTotal.ToString("N2")</td>
                                <td>
                                    <div class="rowact">
                                        <a class="ia" href="@($"/cashier/sales/{item.Id}")" title="View" @onclick:stopPropagation="true"><i class="bi bi-eye"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_page.TotalPages > 1)
            {
                <div class="card-foot">
                    <Pager Page="_page.Page" TotalPages="_page.TotalPages" OnPageChanged="GoToPageAsync" />
                </div>
            }
        </div>
    }
</div>

@code {
    private const int PageSize = 15;

    private PagedResult<PosSaleListItemDto>? _page;
    private int _currentPage = 1;
    private string? _search;
    private int _methodId;
    private string _cashierUserId = "";
    private IReadOnlyList<PaymentMethodDto> _methods = [];
    private IReadOnlyList<PosCashierDto> _cashiers = [];

    protected override async Task OnInitializedAsync()
    {
        _methods = await PaymentMethods.GetAllAsync();
        _cashiers = await Pos.GetCashiersAsync();
        await LoadAsync();
    }

    private async Task LoadAsync() =>
        _page = await Pos.GetPagedAsync(_currentPage, PageSize, _search, null,
            _methodId == 0 ? null : _methodId,
            string.IsNullOrEmpty(_cashierUserId) ? null : _cashierUserId);

    private async Task ReloadAsync() { _currentPage = 1; await LoadAsync(); }
    private async Task OnSearchKeyUp(KeyboardEventArgs e) { _currentPage = 1; await LoadAsync(); }
    private async Task GoToPageAsync(int page) { _currentPage = page; await LoadAsync(); }
    private void Open(int id) => Nav.NavigateTo($"/cashier/sales/{id}");
}
