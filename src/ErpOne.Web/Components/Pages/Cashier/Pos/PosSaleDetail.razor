@page "/cashier/sales/{Id:int}"
@attribute [Authorize(Policy = "cashier.pos.index")]
@rendermode InteractiveServer
@using ErpOne.Application.PosSales
@inject IPosSaleService Pos
@inject ICompanySettingService CompanyService
@inject IJSRuntime JS

<PageTitle>@(_sale?.SaleNumber ?? "Sale")</PageTitle>

<div class="pf">

    <div class="pf-top">
        <div class="crumbs">
            <a href="/cashier/sales">Cashier</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/cashier/sales">Sales History</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(_sale?.SaleNumber ?? "Detail")</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_sale is null)
    {
        <div class="pf-alert warn"><i class="bi bi-exclamation-triangle"></i> Transaction not found.</div>
    }
    else
    {
        <div class="pd-head">
            <h1>@_sale.SaleNumber</h1>
            <span class="badge @(_sale.IsCashPayment ? "b-done" : "b-dark")">@_sale.PaymentMethodName</span>
            <div class="actions">
                <button class="btn btn-primary" @onclick="ReprintAsync"><i class="bi bi-printer"></i> Reprint</button>
            </div>
        </div>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-receipt"></i></span>
                <h2>Information</h2>
            </div>
            <div class="card-b">
                <div class="info-grid">
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-receipt"></i> Receipt No.</span>
                        <span class="v"><span class="grn-no">@_sale.SaleNumber</span></span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-calendar3"></i> Date</span>
                        <span class="v">@_sale.SaleDate.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-person"></i> Cashier</span>
                        <span class="v">@_sale.CashierName</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-box-seam"></i> Warehouse</span>
                        <span class="v">@_sale.WarehouseName</span>
                    </div>
                    <div class="info-cell wide">
                        <span class="k"><i class="bi bi-credit-card"></i> Payment Method</span>
                        <span class="v">@_sale.PaymentMethodName@(_sale.IsCashPayment ? " (cash)" : "")</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-basket"></i></span>
                <h2>Items</h2>
            </div>
            <div class="card-b">
                <div class="table-responsive">
                    <table class="items">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="r">Qty</th>
                                <th class="r">Price</th>
                                <th class="r">Disc%</th>
                                <th class="r">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in _sale.Lines)
                            {
                                <tr>
                                    <td class="prod">
                                        <span class="pn">@l.ProductName</span>
                                        <span class="sku">@l.VariantSku</span>
                                    </td>
                                    <td class="r mono">@l.Quantity</td>
                                    <td class="r mono">@l.UnitPrice.ToString("N2")</td>
                                    <td class="r mono @(l.DiscountPercent == 0 ? "zero" : "")">@(l.DiscountPercent == 0 ? "—" : l.DiscountPercent.ToString("0.##"))</td>
                                    <td class="r mono total">@l.LineTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-cash-coin"></i></span>
                <h2>Summary</h2>
            </div>
            <div class="card-b">
                <div class="cr-kpis">
                    <div class="cr-kpi">
                        <span class="ic sub"><i class="bi bi-receipt-cutoff"></i></span>
                        <div class="tx"><span class="l">Subtotal</span><span class="v">@_sale.Subtotal.ToString("N2")</span></div>
                    </div>
                    <div class="cr-kpi">
                        <span class="ic disc"><i class="bi bi-tag"></i></span>
                        <div class="tx"><span class="l">Discount</span><span class="v">@(_sale.TransactionDiscount > 0 ? "−" : "")@_sale.TransactionDiscount.ToString("N2")</span></div>
                    </div>
                    <div class="cr-kpi">
                        <span class="ic tax"><i class="bi bi-percent"></i></span>
                        <div class="tx"><span class="l">Tax (@_sale.TaxRateSnapshot.ToString("0.##")%)</span><span class="v">@_sale.TaxTotal.ToString("N2")</span></div>
                    </div>
                </div>

                <div class="cr-hero total">
                    <div class="hero-main">
                        <span class="hero-ic"><i class="bi bi-cash-coin"></i></span>
                        <div class="hero-tx">
                            <span class="hero-l">Grand Total</span>
                            <span class="hero-v mono">@_sale.GrandTotal.ToString("N2")</span>
                        </div>
                    </div>
                    <div class="hero-cmp">
                        <div><span class="l">Paid</span><span class="v mono">@_sale.AmountTendered.ToString("N2")</span></div>
                        <div><span class="l">Change</span><span class="v mono">@_sale.ChangeGiven.ToString("N2")</span></div>
                    </div>
                </div>
            </div>
        </section>
    }
</div>

@if (_sale is not null)
{
    <div class="pos-receipt">
        <div class="rc-title">@(string.IsNullOrWhiteSpace(_company?.CompanyName) ? _sale.WarehouseName : _company!.CompanyName)</div>
        @if (!string.IsNullOrWhiteSpace(_company?.Address)) { <div class="rc-sub">@_company!.Address</div> }
        @if (!string.IsNullOrWhiteSpace(_company?.Phone)) { <div class="rc-sub">@_company!.Phone</div> }
        @if (!string.IsNullOrWhiteSpace(_company?.TaxId)) { <div class="rc-sub">NPWP: @_company!.TaxId</div> }
        @if (!string.IsNullOrWhiteSpace(_company?.ReceiptHeader)) { <div class="rc-sub">@_company!.ReceiptHeader</div> }
        <div class="rc-sub">@_sale.WarehouseName · @_sale.SaleNumber<br />@_sale.SaleDate.ToString("dd MMM yyyy HH:mm") · @_sale.CashierName</div>
        <table>
            @foreach (var l in _sale.Lines)
            {
                <tr><td colspan="2">@l.ProductName</td></tr>
                <tr>
                    <td>@l.Quantity x @l.UnitPrice.ToString("N0")@(l.DiscountPercent > 0 ? $" (-{l.DiscountPercent:0.##}%)" : "")</td>
                    <td class="rc-r">@l.LineTotal.ToString("N0")</td>
                </tr>
            }
            <tr class="rc-rule"><td>Subtotal</td><td class="rc-r">@_sale.Subtotal.ToString("N0")</td></tr>
            @if (_sale.TransactionDiscount > 0)
            {
                <tr><td>Discount</td><td class="rc-r">-@_sale.TransactionDiscount.ToString("N0")</td></tr>
            }
            @if (_sale.TaxTotal > 0)
            {
                <tr><td>Tax (@_sale.TaxRateSnapshot.ToString("0.##")%)</td><td class="rc-r">@_sale.TaxTotal.ToString("N0")</td></tr>
            }
            <tr class="rc-grand rc-rule"><td>TOTAL</td><td class="rc-r">@_sale.GrandTotal.ToString("N0")</td></tr>
            <tr><td>@_sale.PaymentMethodName</td><td class="rc-r">@_sale.AmountTendered.ToString("N0")</td></tr>
            @if (_sale.IsCashPayment)
            {
                <tr><td>Change</td><td class="rc-r">@_sale.ChangeGiven.ToString("N0")</td></tr>
            }
        </table>
        <div class="rc-foot">@(string.IsNullOrWhiteSpace(_company?.ReceiptFooter) ? "Thank you for your visit 🙏" : _company!.ReceiptFooter)</div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private PosSaleDto? _sale;
    private CompanySettingDto? _company;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _sale = await Pos.GetByIdAsync(Id);
        _company = await CompanyService.GetAsync();
        _loading = false;
    }

    private async Task ReprintAsync() => await JS.InvokeVoidAsync("appPrint");
}
