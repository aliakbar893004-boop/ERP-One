@page "/cashier/shifts"
@attribute [Authorize(Policy = "cashier.shifts.index")]
@rendermode InteractiveServer
@using FluentValidation
@using ErpOne.Application.Common
@using ErpOne.Application.CashierShifts
@using ErpOne.Application.Warehouses
@using ErpOne.Domain.Entities
@inject ICashierShiftService Shifts
@inject IWarehouseService Warehouses
@inject NavigationManager Nav
@inject SwalService Swal

<PageTitle>Cashier Sessions</PageTitle>

<div class="pi">

    <div class="pi-head">
        <div>
            <nav class="crumbs"><a href="/">Home</a><span class="sep">·</span><span>Cashier</span><span class="sep">·</span><span class="here">Cashier Sessions</span></nav>
            <h1>Cashier Sessions</h1>
            <p>Open a shift, record sales per method, and close with cash reconciliation.</p>
        </div>
        <AuthorizeView Policy="cashier.shifts.create">
            <Authorized>
                <div class="pi-actions">
                    <button class="btn btn-primary" @onclick="() => _showOpen = !_showOpen"><i class="bi bi-unlock"></i> Open Shift</button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_error is not null)
    {
        <div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
    }

    @if (_openShifts.Count > 0)
    {
        <div class="live-shifts">
            @foreach (var s in _openShifts)
            {
                <div class="live-row">
                    <span class="live-dot"><i class="bi bi-unlock-fill"></i></span>
                    <div class="live-tx">
                        <div class="live-t">Open shift · <b class="mono">@s.ShiftNumber</b></div>
                        <div class="live-s">@s.WarehouseName · opened @s.OpenedAt.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                    <div class="live-act">
                        <a class="btn btn-primary btn-sm" href="/cashier/pos"><i class="bi bi-bag-check"></i> Enter Register</a>
                        <a class="btn btn-out btn-sm" href="@($"/cashier/shifts/{s.Id}")"><i class="bi bi-box-arrow-in-right"></i> Details</a>
                    </div>
                </div>
            }
        </div>
    }

    @if (_showOpen)
    {
        <div class="os-panel">
            <div class="os-head">
                <span class="os-ic"><i class="bi bi-unlock-fill"></i></span>
                <div class="os-htx">
                    <h3>Open New Shift</h3>
                    <p>Start a cashier session for a warehouse with its opening cash.</p>
                </div>
                <button type="button" class="os-x" @onclick="() => { _showOpen = false; _error = null; }" title="Close"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="os-body">
                <div class="os-field">
                    <label class="os-lbl">Warehouse</label>
                    <select class="os-ctl" @bind="_openWhId">
                        <option value="0">— select warehouse —</option>
                        @foreach (var w in _warehouses)
                        {
                            <option value="@w.Id">@w.Name</option>
                        }
                    </select>
                </div>
                <div class="os-field">
                    <label class="os-lbl">Opening Cash Float</label>
                    <div class="os-ig">
                        <span class="os-pre">Rp</span>
                        <input class="os-ctl mono has-pre" type="number" min="0" step="1" @bind="_openFloat" placeholder="0" />
                    </div>
                </div>
            </div>
            <div class="os-foot">
                <button class="btn btn-out" @onclick="() => { _showOpen = false; _error = null; }">Cancel</button>
                <button class="btn btn-primary" @onclick="OpenShiftAsync" disabled="@_busy">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-unlock"></i>
                    }
                    Open shift
                </button>
            </div>
        </div>
    }

    <div class="toolbar">
        <div class="search">
            <i class="bi bi-search"></i>
            <input placeholder="Search shift number or cashier…" @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
        <div class="chips">
            <button class="chip @(_statusFilter is null ? "on" : "")" @onclick="() => SetStatusAsync(null)">All</button>
            @foreach (var s in Enum.GetValues<CashierShiftStatus>())
            {
                <button class="chip @(_statusFilter == s ? "on" : "")" @onclick="() => SetStatusAsync(s)">@s</button>
            }
        </div>
    </div>

    @if (_page is null)
    {
        <div class="pi-loading"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading…</div>
    }
    else if (_page.Total == 0)
    {
        <div class="empty">
            <div class="empty-ic"><i class="bi bi-cash-stack"></i></div>
            <p>No matching cashier sessions yet.</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-top">
                <span class="n">Showing <b>@((_page.Page - 1) * PageSize + 1)–@Math.Min(_page.Page * PageSize, _page.Total)</b> of <b>@_page.Total.ToString("N0")</b></span>
            </div>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Shift No.</th>
                            <th>Warehouse</th>
                            <th>Cashier</th>
                            <th>Opened</th>
                            <th>Closed</th>
                            <th class="c">Total Sales</th>
                            <th class="c">Status</th>
                            <th style="width:60px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _page.Items)
                        {
                            <tr @onclick="() => Open(item.Id)">
                                <td class="code mono">@item.ShiftNumber</td>
                                <td class="nm">@item.WarehouseName</td>
                                <td class="nm">@item.CashierName</td>
                                <td class="code">@item.OpenedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td class="code">@(item.ClosedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                                <td class="c mono">@item.TotalSalesAmount.ToString("N2")</td>
                                <td class="c"><span class="badge @PillClass(item.Status)">@item.Status</span></td>
                                <td>
                                    <div class="rowact">
                                        <a class="ia" href="@($"/cashier/shifts/{item.Id}")" title="View" @onclick:stopPropagation="true"><i class="bi bi-eye"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_page.TotalPages > 1)
            {
                <div class="card-foot">
                    <Pager Page="_page.Page" TotalPages="_page.TotalPages" OnPageChanged="GoToPageAsync" />
                </div>
            }
        </div>
    }
</div>

@code {
    private const int PageSize = 15;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private PagedResult<CashierShiftListItemDto>? _page;
    private IReadOnlyList<CashierShiftDto> _openShifts = [];
    private IReadOnlyList<WarehouseDto> _warehouses = [];
    private int _currentPage = 1, _openWhId;
    private decimal _openFloat;
    private string? _search;
    private CashierShiftStatus? _statusFilter;
    private bool _showOpen, _busy;
    private string _userId = "", _userName = "";
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthStateTask).User;
        _userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _userName = user.Identity?.Name ?? "";
        _warehouses = (await Warehouses.GetAllAsync()).Where(w => w.IsActive).ToList();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _openShifts = await Shifts.GetOpenShiftsAsync();
        _page = await Shifts.GetPagedAsync(_currentPage, PageSize, _search, _statusFilter);
    }

    private async Task OpenShiftAsync()
    {
        _error = null; _busy = true;
        try
        {
            if (_openWhId <= 0) { _error = "Please select a warehouse first."; return; }
            await Shifts.OpenAsync(_userId, _userName, new OpenShiftRequest(_openWhId, _openFloat));
            _showOpen = false; _openFloat = 0m; _openWhId = 0;
            await LoadAsync();
            await Swal.ToastAsync("success", "Shift opened");
        }
        catch (ValidationException ex) { _error = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)); }
        finally { _busy = false; }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e) { _currentPage = 1; await LoadAsync(); }
    private async Task SetStatusAsync(CashierShiftStatus? status) { _statusFilter = status; _currentPage = 1; await LoadAsync(); }
    private async Task GoToPageAsync(int page) { _currentPage = page; await LoadAsync(); }
    private void Open(int id) => Nav.NavigateTo($"/cashier/shifts/{id}");

    private static string PillClass(string status) => status switch
    {
        "Open" => "b-ok",
        "Closed" => "b-off",
        _ => "b-dark"
    };
}
