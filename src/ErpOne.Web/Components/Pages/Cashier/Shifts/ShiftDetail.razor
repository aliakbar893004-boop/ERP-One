@page "/cashier/shifts/{Id:int}"
@attribute [Authorize(Policy = "cashier.shifts.index")]
@rendermode InteractiveServer
@using System.Globalization
@using FluentValidation
@using ErpOne.Application.CashierShifts
@inject ICashierShiftService Shifts
@inject NavigationManager Nav
@inject SwalService Swal

<PageTitle>@(_shift?.ShiftNumber ?? "Cashier Session")</PageTitle>

<div class="pf pf-detail">

    <div class="pf-top">
        <div class="crumbs">
            <a href="/cashier/shifts">Cashier</a>
            <i class="bi bi-chevron-right"></i>
            <a href="/cashier/shifts">Cashier Sessions</a>
            <i class="bi bi-chevron-right"></i>
            <span class="here">@(_shift?.ShiftNumber ?? "Detail")</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (_shift is null)
    {
        <div class="pf-alert warn"><i class="bi bi-exclamation-triangle"></i> Cashier session not found.</div>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="pf-alert err"><i class="bi bi-exclamation-octagon"></i> @_error</div>
        }

        <div class="pd-head">
            <h1>@_shift.ShiftNumber</h1>
            <span class="badge @StatusClass(_shift.Status)">@_shift.Status</span>
            <div class="actions">
                @if (_shift.Status == "Open")
                {
                    <a class="btn btn-line" href="/cashier/pos"><i class="bi bi-bag-check"></i> Enter Register</a>
                }
                @if (CanClose)
                {
                    <AuthorizeView Policy="cashier.shifts.close">
                        <Authorized>
                            <button class="btn btn-primary" @onclick="() => _showClose = !_showClose" disabled="@_busy"><i class="bi bi-lock"></i> Close Shift</button>
                        </Authorized>
                    </AuthorizeView>
                }
            </div>
        </div>

        @if (_showClose && CanClose)
        {
            <section class="card">
                <div class="card-h">
                    <span class="hd-ic"><i class="bi bi-lock-fill"></i></span>
                    <h2>Close Shift</h2>
                </div>
                <div class="card-b">
                    <div class="cs-form">
                        <div class="f">
                            <label class="fl">Counted Physical Cash</label>
                            <div class="ig">
                                <span class="ig-pre">Rp</span>
                                <input class="ctl mono has-pre" type="number" min="0" step="1" @bind="_countedCash" placeholder="0" />
                            </div>
                        </div>
                        <div class="f">
                            <label class="fl">Note <span class="opt">(optional)</span></label>
                            <input class="ctl" maxlength="500" @bind="_closingNote" placeholder="e.g. variance due to…" />
                        </div>
                    </div>

                    <div class="cs-hint">
                        <i class="bi bi-info-circle"></i>
                        <span>Expected cash right now is <b class="mono">@_shift.ExpectedCash.ToString("N2")</b> — opening float <span class="mono">@_shift.OpeningFloat.ToString("N2")</span> + cash sales <span class="mono">@_shift.CashSalesTotal.ToString("N2")</span>.</span>
                    </div>

                    <div class="cs-actions">
                        <button class="btn btn-line" @onclick="() => { _showClose = false; _error = null; }">Cancel</button>
                        <button class="btn btn-primary" @onclick="CloseShiftAsync" disabled="@_busy"><i class="bi bi-check-lg"></i> Confirm Close</button>
                    </div>
                </div>
            </section>
        }

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-receipt"></i></span>
                <h2>Information</h2>
            </div>
            <div class="card-b">
                <div class="info-grid">
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-receipt"></i> Shift No.</span>
                        <span class="v"><span class="grn-no">@_shift.ShiftNumber</span></span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-box-seam"></i> Warehouse</span>
                        <span class="v">@_shift.WarehouseName</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-person"></i> Cashier</span>
                        <span class="v">@_shift.CashierName</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-calendar3"></i> Opened</span>
                        <span class="v">@_shift.OpenedAt.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="info-cell">
                        <span class="k"><i class="bi bi-cash"></i> Opening Float</span>
                        <span class="v mono">@_shift.OpeningFloat.ToString("N2")</span>
                    </div>
                    @if (_shift.Status == "Closed")
                    {
                        <div class="info-cell">
                            <span class="k"><i class="bi bi-calendar-check"></i> Closed</span>
                            <span class="v">@(_shift.ClosedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</span>
                        </div>
                        <div class="info-cell wide">
                            <span class="k"><i class="bi bi-sticky"></i> Note</span>
                            <span class="v @(string.IsNullOrEmpty(_shift.ClosingNote) ? "muted-v" : "")">@(_shift.ClosingNote ?? "—")</span>
                        </div>
                    }
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-cash-coin"></i></span>
                <h2>Cash Reconciliation</h2>
            </div>
            <div class="card-b">
                @{
                    var expected = _shift.ExpectedCash;
                    var floatPct = expected > 0 ? _shift.OpeningFloat / expected * 100m : 0m;
                    var salesPct = expected > 0 ? _shift.CashSalesTotal / expected * 100m : 0m;
                }

                <div class="cr-kpis">
                    <div class="cr-kpi">
                        <span class="ic float"><i class="bi bi-wallet2"></i></span>
                        <div class="tx"><span class="l">Opening Float</span><span class="v">@_shift.OpeningFloat.ToString("N2")</span></div>
                    </div>
                    <div class="cr-kpi">
                        <span class="ic sales"><i class="bi bi-cash-stack"></i></span>
                        <div class="tx"><span class="l">Cash Sales</span><span class="v">@_shift.CashSalesTotal.ToString("N2")</span></div>
                    </div>
                    <div class="cr-kpi accent">
                        <span class="ic"><i class="bi bi-calculator"></i></span>
                        <div class="tx"><span class="l">Expected Cash</span><span class="v">@_shift.ExpectedCash.ToString("N2")</span></div>
                    </div>
                </div>

                <div class="cr-meter">
                    <div class="cr-meter-head"><span>Expected cash composition</span></div>
                    <div class="cr-bar">
                        <div class="seg float" style="width:@(floatPct.ToString("0.##", CultureInfo.InvariantCulture))%"></div>
                        <div class="seg sales" style="width:@(salesPct.ToString("0.##", CultureInfo.InvariantCulture))%"></div>
                    </div>
                    <div class="cr-legend">
                        <span class="lg"><i class="dot float"></i> Opening Float · <b class="mono">@floatPct.ToString("0", CultureInfo.InvariantCulture)%</b></span>
                        <span class="lg"><i class="dot sales"></i> Cash Sales · <b class="mono">@salesPct.ToString("0", CultureInfo.InvariantCulture)%</b></span>
                    </div>
                </div>

                @if (_shift.Status == "Closed")
                {
                    var variance = _shift.CashVariance ?? 0m;
                    var vClass = variance < 0 ? "short" : variance > 0 ? "over" : "ok";
                    var vIcon = variance < 0 ? "bi-arrow-down-circle-fill" : variance > 0 ? "bi-arrow-up-circle-fill" : "bi-check-circle-fill";
                    var vLabel = variance < 0 ? "Cash Short" : variance > 0 ? "Cash Over" : "Balanced";

                    <div class="cr-hero @vClass">
                        <div class="hero-main">
                            <span class="hero-ic"><i class="bi @vIcon"></i></span>
                            <div class="hero-tx">
                                <span class="hero-l">@vLabel</span>
                                <span class="hero-v mono">@variance.ToString("N2")</span>
                            </div>
                        </div>
                        <div class="hero-cmp">
                            <div><span class="l">Counted</span><span class="v mono">@(_shift.CountedCash?.ToString("N2") ?? "—")</span></div>
                            <div><span class="l">Expected</span><span class="v mono">@_shift.ExpectedCash.ToString("N2")</span></div>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="card">
            <div class="card-h">
                <span class="hd-ic"><i class="bi bi-list-columns"></i></span>
                <h2>Totals by Method</h2>
            </div>
            <div class="card-b">
                @if (_shift.MethodTotals.Count == 0)
                {
                    <p style="color:var(--muted)">No sales in this shift yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="items">
                            <thead>
                                <tr>
                                    <th>Method</th>
                                    <th class="r">Transactions</th>
                                    <th class="r">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in _shift.MethodTotals)
                                {
                                    <tr>
                                        <td class="pn">@m.MethodName</td>
                                        <td class="r mono">@m.TransactionCount</td>
                                        <td class="r mono total">@m.TotalAmount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td class="gt-l">Grand Total</td>
                                    <td class="r mono">@_shift.TransactionCount</td>
                                    <td class="r grand">@_shift.TotalSalesAmount.ToString("N2")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>
        </section>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private CashierShiftDto? _shift;
    private bool _loading = true, _busy, _showClose;
    private decimal _countedCash;
    private string? _closingNote;
    private string _userId = "";
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _userId = (await AuthStateTask).User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _shift = await Shifts.GetByIdAsync(Id);
        _loading = false;
    }

    private bool CanClose => _shift is { Status: "Open" } && _shift.CashierUserId == _userId;

    private async Task CloseShiftAsync()
    {
        _error = null; _busy = true;
        try
        {
            if (!await Swal.ConfirmAsync("Close this shift?", "Once closed it can't be changed.", "Yes, Close")) { _busy = false; return; }
            await Shifts.CloseAsync(Id, _userId, new CloseShiftRequest(_countedCash, _closingNote));
            _showClose = false;
            await LoadAsync();
            await Swal.ToastAsync("success", "Shift closed");
        }
        catch (ValidationException ex) { _error = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)); }
        finally { _busy = false; }
    }

    private static string StatusClass(string status) => status switch
    {
        "Open" => "b-ok",
        "Closed" => "b-done",
        _ => "b-dark"
    };
}
