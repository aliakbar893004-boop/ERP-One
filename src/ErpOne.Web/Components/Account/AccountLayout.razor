                    <rect x="34" y="109" width="36" height="5" rx="2" fill="rgba(255,255,255,0.18)"/>
                    <rect x="20" y="127" width="10" height="10" rx="3" fill="rgba(255,255,255,0.18)"/>
                    <rect x="34" y="129" width="28" height="5" rx="2" fill="rgba(255,255,255,0.18)"/>
                    <rect x="20" y="147" width="10" height="10" rx="3" fill="rgba(255,255,255,0.18)"/>
                    <rect x="34" y="149" width="34" height="5" rx="2" fill="rgba(255,255,255,0.18)"/>
                    <!-- Stat cards -->
                    <rect x="94" y="58" width="86" height="58" rx="10" fill="rgba(255,255,255,0.09)"/>
                    <rect x="106" y="70" width="38" height="5" rx="2" fill="rgba(255,255,255,0.35)"/>
                    <rect x="106" y="82" width="56" height="10" rx="3" fill="rgba(255,255,255,0.7)"/>
                    <rect x="106" y="98" width="28" height="5" rx="2" fill="rgba(134,239,172,0.8)"/>
                    <rect x="190" y="58" width="86" height="58" rx="10" fill="rgba(255,255,255,0.09)"/>
                    <rect x="202" y="70" width="38" height="5" rx="2" fill="rgba(255,255,255,0.35)"/>
                    <rect x="202" y="82" width="56" height="10" rx="3" fill="rgba(255,255,255,0.7)"/>
