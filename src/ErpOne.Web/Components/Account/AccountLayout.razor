            <h2 class="promo-headline">One Platform, Every Business Need</h2>
            <p class="promo-subtext">
                Manage operations, monitor performance, and make data-driven decisions with ERP_One — an integrated management solution for modern business.
            </p>

            <div class="promo-feats">
                <div class="promo-feat">
                    <div class="pf-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="20" x2="18" y2="10"></line>
                            <line x1="12" y1="20" x2="12" y2="4"></line>
                            <line x1="6" y1="20" x2="6" y2="14"></line>
                        </svg>
                    </div>
                    <div class="pf-text">
                        <strong>Real-Time Dashboard</strong>
                        <span>Monitor all business activity live and accurately</span>
                    </div>
                </div>
                <div class="promo-feat">
                    <div class="pf-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <div class="pf-text">
                        <strong>User Management</strong>
                        <span>Manage team roles and access easily and securely</span>
                    </div>
                </div>
                <div class="promo-feat">
                    <div class="pf-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                    </div>
                    <div class="pf-text">
                        <strong>Reports &amp; Analytics</strong>
                        <span>Deep insights for making the right decisions</span>
                    </div>
                </div>
            </div>
        </div>
    </aside>

    <div class="account-form-panel">
        <div class="account-card-wrap">
            @Body
        </div>
        <p class="account-footer">&copy; @DateTime.Now.Year ERP_One. All rights reserved.</p>
    </div>
</div>
