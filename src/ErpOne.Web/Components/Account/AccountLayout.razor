                    <circle cx="64" cy="28" r="5" fill="rgba(255,255,255,0.25)"/>
                    <rect x="80" y="24" width="60" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
                    <!-- Sidebar -->
                    <rect x="8" y="48" width="76" height="224" fill="rgba(255,255,255,0.04)"/>
                    <!-- Active indicator -->
                    <rect x="8" y="64" width="3" height="16" rx="1.5" fill="rgba(147,197,253,1)"/>
