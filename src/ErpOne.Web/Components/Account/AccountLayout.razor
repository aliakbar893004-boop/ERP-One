                    <rect x="168" y="189" width="14" height="35" rx="3" fill="rgba(99,155,255,0.55)"/>
                    <rect x="188" y="176" width="14" height="48" rx="3" fill="rgba(37,99,235,0.95)"/>
                    <rect x="208" y="184" width="14" height="40" rx="3" fill="rgba(99,155,255,0.6)"/>
                    <rect x="228" y="194" width="14" height="30" rx="3" fill="rgba(99,155,255,0.45)"/>
                    <!-- Donut chart -->
                    <rect x="286" y="128" width="98" height="106" rx="10" fill="rgba(255,255,255,0.06)"/>
                    <rect x="298" y="140" width="55" height="5" rx="2" fill="rgba(255,255,255,0.3)"/>
                    <circle cx="335" cy="192" r="28" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="14"/>
                    <circle cx="335" cy="192" r="28" fill="none" stroke="rgba(37,99,235,0.9)" stroke-width="14" stroke-dasharray="88 88" stroke-dashoffset="22"/>
                    <circle cx="335" cy="192" r="28" fill="none" stroke="rgba(134,239,172,0.7)" stroke-width="14" stroke-dasharray="48 128" stroke-dashoffset="-66"/>
