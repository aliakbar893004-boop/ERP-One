<?xml version="1.0" encoding="utf-8"?>
<!--
  Konfigurasi IIS untuk hosting in-process (ASP.NET Core Module v2).
  processPath/arguments akan diisi otomatis oleh `dotnet publish`.
  Windows Authentication diaktifkan di level IIS (lihat DEPLOY-IIS.md), bukan di sini.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\ErpOne.Web.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
